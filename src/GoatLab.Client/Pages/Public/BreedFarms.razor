@page "/breeds/{BreedSlug}"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.LandingLayout
@using GoatLab.Shared.DTOs
@inject HttpClient Http

<PageTitle>@DisplayName breeders — GoatLab</PageTitle>
<HeadContent>
    <meta name="description" content="@DisplayName goats for sale from GoatLab breeders. Browse farms, see starting prices, and contact sellers directly." />
</HeadContent>

<div class="breed-farms">
    <div class="container">
        <MudBreadcrumbs Items="Crumbs" Class="px-0" />

        <MudText Typo="Typo.overline" Color="Color.Primary" Style="letter-spacing:2px;">Breed directory</MudText>
        <MudText Typo="Typo.h3" Style="font-weight:700;margin:0 0 8px 0;">@DisplayName breeders</MudText>

        @if (loading)
        {
            <MudProgressCircular Indeterminate Color="Color.Primary" Class="mt-4" />
        }
        else if (farms is null || farms.Count == 0)
        {
            <MudPaper Class="pa-6 text-center" Outlined Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:3rem;color:#bbb;" />
                <MudText Typo="Typo.body1" Class="mt-3">No @DisplayName farms listed right now.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/breeds" Class="mt-3">Browse all breeds</MudButton>
            </MudPaper>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                @farms.Count farm@(farms.Count == 1 ? "" : "s") listed. Click a farm to view their current @DisplayName goats.
            </MudText>

            <div class="farms-grid">
                @foreach (var f in farms)
                {
                    <a class="farm-card" href="@($"/pub/{f.FarmSlug}")">
                        <div class="farm-card-photo">
                            @if (!string.IsNullOrEmpty(f.HeroPhotoUrl))
                            {
                                <img src="@f.HeroPhotoUrl" alt="@f.FarmName" loading="lazy" />
                            }
                            else
                            {
                                <div class="farm-card-noimg">
                                    <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                </div>
                            }
                        </div>
                        <div class="farm-card-body">
                            <MudText Typo="Typo.h6" Style="margin:0;font-weight:700;">@f.FarmName</MudText>
                            @if (!string.IsNullOrEmpty(f.Location))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="font-size:1rem;vertical-align:text-bottom;" /> @f.Location
                                </MudText>
                            }
                            <div class="d-flex justify-space-between align-center mt-2">
                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                    @f.ListingCount @DisplayName
                                </MudChip>
                                @if (f.StartingPriceCents.HasValue)
                                {
                                    <MudText Typo="Typo.body2" Style="color:#2e7d32;font-weight:700;">
                                        from $@((f.StartingPriceCents.Value / 100m).ToString("N0"))
                                    </MudText>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
.breed-farms { padding: 32px 0; }
.farms-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; margin-top: 16px; }
.farm-card { display: block; text-decoration: none; color: inherit; background: #fff; border: 1px solid #e0e0e0; border-radius: 10px; overflow: hidden; transition: transform 0.15s ease, box-shadow 0.15s ease; }
.farm-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
.mud-theme-dark .farm-card { background: #1e1e1e; border-color: #333; }
.farm-card-photo { aspect-ratio: 16/9; overflow: hidden; background: #f5f5f5; }
.farm-card-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
.farm-card-noimg { display: flex; align-items: center; justify-content: center; height: 100%; color: #bbb; font-size: 3rem; }
.farm-card-body { padding: 14px; }
</style>

@code {
    [Parameter] public string BreedSlug { get; set; } = string.Empty;

    private List<BreedFarmDto>? farms;
    private bool loading = true;
    private string DisplayName => farms?.FirstOrDefault() is null
        ? Humanize(BreedSlug)
        : Humanize(BreedSlug);

    private List<BreadcrumbItem> Crumbs => new()
    {
        new BreadcrumbItem("Breeds", href: "/breeds"),
        new BreadcrumbItem(DisplayName, href: null, disabled: true),
    };

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        try
        {
            farms = await Http.GetFromJsonAsync<List<BreedFarmDto>>($"api/public/breeds/{BreedSlug}");
        }
        catch (HttpRequestException)
        {
            farms = null;
        }
        finally
        {
            loading = false;
        }
    }

    // "nigerian-dwarf" → "Nigerian Dwarf" for the headline. Good enough for SEO
    // and human display; the API's own DisplayName isn't surfaced here because
    // this page can be hit directly before the breeds-index has loaded.
    private static string Humanize(string slug)
    {
        if (string.IsNullOrWhiteSpace(slug)) return "Breed";
        return string.Join(" ", slug.Split('-')
            .Where(s => s.Length > 0)
            .Select(s => char.ToUpper(s[0]) + s.Substring(1)));
    }
}
