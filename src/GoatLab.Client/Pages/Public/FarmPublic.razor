@page "/pub/{Slug}"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.LandingLayout
@using GoatLab.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Goats for sale — GoatLab</PageTitle>

@if (loading)
{
    <div class="container py-12 text-center">
        <MudProgressCircular Indeterminate Color="Color.Primary" />
    </div>
}
else if (goats is null)
{
    <div class="container py-12 text-center">
        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:4rem;color:#bbb;" />
        <MudText Typo="Typo.h5" Class="mt-4">Farm not found</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            The owner may not have enabled their public page.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Href="/">Back to GoatLab</MudButton>
    </div>
}
else
{
    <div class="public-farm">
        <div class="container">
            <MudText Typo="Typo.overline" Color="Color.Primary" Style="letter-spacing:2px;">@Slug</MudText>
            <MudText Typo="Typo.h3" Style="font-weight:700;margin:0 0 16px 0;">Goats for sale</MudText>

            @if (goats.Count == 0)
            {
                <MudPaper Class="pa-6 text-center" Outlined Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.Pets" Style="font-size:3rem;color:#bbb;" />
                    <MudText Typo="Typo.body1" Class="mt-3">No goats currently listed for sale.</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">Check back soon.</MudText>
                </MudPaper>
            }
            else
            {
                <div class="public-farm-grid">
                    @foreach (var g in goats)
                    {
                        <a class="public-farm-card" href="@($"/pub/{Slug}/{g.Id}")">
                            <div class="public-farm-card-photo">
                                @if (!string.IsNullOrEmpty(g.PrimaryPhotoUrl))
                                {
                                    <img src="@g.PrimaryPhotoUrl" alt="@g.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="public-farm-card-noimg">
                                        <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                    </div>
                                }
                            </div>
                            <div class="public-farm-card-body">
                                <MudText Typo="Typo.h6" Style="margin:0;">@g.Name</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @(g.Breed ?? "Unknown breed") · @g.Gender
                                    @if (g.DateOfBirth.HasValue) { <span> · @AgeString(g.DateOfBirth.Value)</span> }
                                </MudText>
                                @if (g.AskingPriceCents.HasValue)
                                {
                                    <MudText Typo="Typo.h6" Style="color:#2e7d32;margin-top:6px;font-weight:700;">
                                        $@((g.AskingPriceCents.Value / 100m).ToString("N0"))
                                    </MudText>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
.public-farm { padding: 32px 0; }
.public-farm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-top: 24px; }
.public-farm-card { display: block; text-decoration: none; color: inherit; background: #fff; border: 1px solid #e0e0e0; border-radius: 10px; overflow: hidden; transition: transform 0.15s ease, box-shadow 0.15s ease; }
.public-farm-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
.mud-theme-dark .public-farm-card { background: #1e1e1e; border-color: #333; }
.public-farm-card-photo { aspect-ratio: 4/3; overflow: hidden; background: #f5f5f5; }
.public-farm-card-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
.public-farm-card-noimg { display: flex; align-items: center; justify-content: center; height: 100%; color: #bbb; font-size: 3rem; }
.public-farm-card-body { padding: 12px 14px; }
</style>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private List<PublicGoatListItemDto>? goats;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            goats = await Http.GetFromJsonAsync<List<PublicGoatListItemDto>>($"api/public/farms/{Slug}/goats");
        }
        catch (HttpRequestException)
        {
            goats = null;
        }
        finally
        {
            loading = false;
        }
    }

    private static string AgeString(DateTime dob)
    {
        var months = (int)((DateTime.UtcNow - dob).TotalDays / 30.44);
        if (months < 12) return months + " mo";
        var years = months / 12;
        var remMonths = months % 12;
        return remMonths == 0 ? years + " yr" : $"{years} yr {remMonths} mo";
    }
}
