@using GoatLab.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.BookmarkAdd" Class="mr-2" />
            <MudText Typo="Typo.h6">Reserve @GoatName</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Pay a <strong>$@((DepositCents / 100m).ToString("N0")) USD</strong> deposit to hold this goat.
            The seller will be notified and reach out to coordinate pickup. The deposit is applied to the final purchase price — refund policy is set by the farm.
        </MudText>

        <MudTextField @bind-Value="buyerName" Label="Your name" Variant="Variant.Outlined" Required Class="mb-2" />
        <MudTextField @bind-Value="buyerEmail" Label="Email" InputType="InputType.Email" Variant="Variant.Outlined" Required Class="mb-2" />
        <MudTextField @bind-Value="buyerPhone" Label="Phone (optional)" Variant="Variant.Outlined" Class="mb-2" />
        <MudTextField @bind-Value="notes" Label="Notes for the seller (optional)"
                      Variant="Variant.Outlined" Lines="3" MaxLength="500" />

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
            You'll be redirected to Stripe Checkout to complete the payment securely.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="submitting">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Lock"
                   OnClick="Submit" Disabled="submitting">
            @(submitting ? "Redirecting..." : $"Pay ${DepositCents / 100m:N0}")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string Slug { get; set; } = string.Empty;
    [Parameter] public int GoatId { get; set; }
    [Parameter] public string GoatName { get; set; } = string.Empty;
    [Parameter] public int DepositCents { get; set; }

    private string buyerName = string.Empty;
    private string buyerEmail = string.Empty;
    private string? buyerPhone;
    private string? notes;
    private bool submitting;

    private void Cancel() => Dialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(buyerName) || string.IsNullOrWhiteSpace(buyerEmail))
        {
            Snackbar.Add("Name and email are required.", Severity.Warning);
            return;
        }

        submitting = true;
        try
        {
            var req = new PublicReservationRequest(buyerEmail.Trim(), buyerName.Trim(), buyerPhone?.Trim(), notes?.Trim());
            var resp = await Http.PostAsJsonAsync($"api/public/farms/{Slug}/goats/{GoatId}/reserve", req);
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                Snackbar.Add($"Could not start checkout: {err}", Severity.Error);
                return;
            }
            var dto = await resp.Content.ReadFromJsonAsync<RedirectUrl>();
            if (dto?.Url is null)
            {
                Snackbar.Add("Checkout URL missing — try again.", Severity.Error);
                return;
            }
            Dialog.Close(DialogResult.Ok(dto.Url));
        }
        finally
        {
            submitting = false;
        }
    }

    private record RedirectUrl(string Url);
}
