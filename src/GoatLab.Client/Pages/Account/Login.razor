@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.AuthLayout
@using GoatLab.Shared.DTOs
@inject AuthService AuthApi
@inject CookieAuthStateProvider AuthState
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Sign in — GoatLab</PageTitle>

<MudPaper Elevation="4" Class="pa-8" Style="max-width: 440px; margin: 4rem auto;">
    <MudText Typo="Typo.h5" GutterBottom="true">Sign in to GoatLab</MudText>
    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
        Welcome back. Enter your credentials below.
    </MudText>

    <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />
        <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined"
                      InputType="InputType.Email" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_model.Password" Label="Password" Variant="Variant.Outlined"
                      InputType="InputType.Password" Required="true" Class="mb-3" />
        <MudCheckBox @bind-Value="_model.RememberMe" Label="Keep me signed in" Class="mb-4" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">
                @_error
                @if (_emailUnconfirmed)
                {
                    <div class="mt-2">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   OnClick="ResendConfirmationAsync" Disabled="_busy">
                            Resend confirmation email
                        </MudButton>
                    </div>
                }
            </MudAlert>
        }

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                   Color="Color.Primary" FullWidth="true" Disabled="_busy">
            @(_busy ? "Signing in…" : "Sign in")
        </MudButton>
    </EditForm>

    <div class="d-flex justify-space-between mt-4">
        <MudLink Href="/forgot-password" Typo="Typo.body2">Forgot your password?</MudLink>
        <MudLink Href="/register" Typo="Typo.body2">Create an account</MudLink>
    </div>
</MudPaper>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _emailUnconfirmed;
    private bool _busy;

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        _emailUnconfirmed = false;

        var result = await AuthApi.LoginAsync(new LoginRequest(_model.Email, _model.Password, _model.RememberMe));
        _busy = false;

        if (!result.Ok)
        {
            _error = result.Error ?? "Invalid email or password.";
            _emailUnconfirmed = result.EmailUnconfirmed;
            return;
        }

        AuthState.NotifyUserChanged(result.User);

        if (result.User is null || result.User.Memberships.Count == 0)
            Nav.NavigateTo("/dashboard");
        else if (result.User.CurrentTenantId is null)
            Nav.NavigateTo("/select-farm");
        else
            Nav.NavigateTo("/dashboard");
    }

    private async Task ResendConfirmationAsync()
    {
        _busy = true;
        try
        {
            await AuthApi.ResendConfirmationAsync(_model.Email);
            Snackbar.Add("If that email is on file and unconfirmed, we've sent a new link.", Severity.Info);
        }
        finally { _busy = false; }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
}
