@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.AuthLayout
@using GoatLab.Shared.DTOs
@inject AuthService AuthApi
@inject CookieAuthStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Sign in — GoatLab</PageTitle>

<MudPaper Elevation="4" Class="pa-8" Style="max-width: 440px; margin: 4rem auto;">
    <MudText Typo="Typo.h5" GutterBottom="true">Sign in to GoatLab</MudText>
    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
        Welcome back. Enter your credentials below.
    </MudText>

    <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />
        <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined"
                      InputType="InputType.Email" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_model.Password" Label="Password" Variant="Variant.Outlined"
                      InputType="InputType.Password" Required="true" Class="mb-3" />
        <MudCheckBox @bind-Value="_model.RememberMe" Label="Keep me signed in" Class="mb-4" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
        }

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                   Color="Color.Primary" FullWidth="true" Disabled="_busy">
            @(_busy ? "Signing in…" : "Sign in")
        </MudButton>
    </EditForm>

    <MudText Typo="Typo.body2" Class="mt-4" Align="Align.Center">
        New to GoatLab? <MudLink Href="/register">Create an account</MudLink>
    </MudText>
</MudPaper>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;

        var (ok, err, user) = await AuthApi.LoginAsync(new LoginRequest(_model.Email, _model.Password, _model.RememberMe));
        _busy = false;

        if (!ok)
        {
            _error = "Invalid email or password.";
            return;
        }

        AuthState.NotifyUserChanged(user);

        if (user is null || user.Memberships.Count == 0)
            Nav.NavigateTo("/dashboard");
        else if (user.CurrentTenantId is null)
            Nav.NavigateTo("/select-farm");
        else
            Nav.NavigateTo("/dashboard");
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
}
