@page "/forgot-password"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.AuthLayout
@inject AuthService AuthApi

<PageTitle>Forgot password — GoatLab</PageTitle>

<MudPaper Elevation="4" Class="pa-8" Style="max-width: 440px; margin: 4rem auto;">
    @if (_sent)
    {
        <div class="text-center">
            <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Class="mt-2 mb-2">Check your inbox</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                If an account exists for <strong>@_email</strong>, we've sent a password-reset link.
                The link expires in a few hours.
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth Href="/login">
                Back to sign in
            </MudButton>
        </div>
    }
    else
    {
        <MudText Typo="Typo.h5" GutterBottom="true">Reset your password</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            Enter the email you signed up with. We'll send you a link to reset your password.
        </MudText>

        <EditForm Model="this" OnValidSubmit="SubmitAsync">
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          InputType="InputType.Email" Required="true" Class="mb-4" />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                       Color="Color.Primary" FullWidth Disabled="_busy">
                @(_busy ? "Sending…" : "Send reset link")
            </MudButton>
        </EditForm>
        <MudText Typo="Typo.body2" Class="mt-4" Align="Align.Center">
            <MudLink Href="/login">Back to sign in</MudLink>
        </MudText>
    }
</MudPaper>

@code {
    private string _email = string.Empty;
    private bool _busy;
    private bool _sent;

    private async Task SubmitAsync()
    {
        _busy = true;
        try
        {
            await AuthApi.ForgotPasswordAsync(_email);
            _sent = true;
        }
        finally { _busy = false; }
    }
}
