@page "/farm-settings"
@using GoatLab.Shared.Models
@inject TenantSettingsService SettingsApi
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Farm settings — GoatLab</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Farm settings</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Update your farm's display name, location, and unit system. Only farm owners can make changes.
    </MudText>

    @if (_settings is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudPaper Class="pa-6">
            <MudTextField @bind-Value="_name" Label="Farm name" Required="true"
                          HelperText="How the farm appears in the app and on emails." Class="mb-3" />

            <MudTextField Value="_settings.Slug" Label="URL slug" ReadOnly="true"
                          HelperText="Immutable. Used in URLs and Stripe customer records." Class="mb-3" />

            <MudTextField @bind-Value="_location" Label="Location"
                          HelperText="City, state or any description — shown on reports." Class="mb-3" />

            <MudSelect T="TenantUnits" @bind-Value="_units" Label="Units" Class="mb-4">
                <MudSelectItem Value="TenantUnits.Imperial">Imperial (lb, ft, °F)</MudSelectItem>
                <MudSelectItem Value="TenantUnits.Metric">Metric (kg, m, °C)</MudSelectItem>
            </MudSelect>

            <MudSwitch T="bool" @bind-Value="_alertEmailEnabled" Color="Color.Primary" Class="mb-4"
                       Label="Email me a daily summary of new alerts"
                       UncheckedColor="Color.Default" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4 d-block">
                Sent at 07:00 UTC to the farm owner. Only fires when there are new alerts in the last 24 hours.
            </MudText>

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-2">Public farm page</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                When on, anyone with the link can see goats you've marked "for sale".
                URL: <MudLink Href="@PublicFarmUrl" Target="_blank">@PublicFarmUrl</MudLink>
            </MudText>
            <MudSwitch T="bool" @bind-Value="_publicProfileEnabled" Color="Color.Primary" Class="mb-3"
                       Label="Enable public farm page"
                       UncheckedColor="Color.Default" />
            <MudTextField @bind-Value="_publicContactEmail" Label="Public contact email"
                          HelperText="Shown on the public page so buyers can reach you. Defaults to nothing — leave blank to hide."
                          Class="mb-4" />


            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
            }

            <div class="d-flex">
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SaveAsync" Disabled="_busy || !HasChanges">
                    @(_busy ? "Saving…" : "Save")
                </MudButton>
            </div>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4 d-block">
                Farm created @_settings.CreatedAt.ToLocalTime().ToString("MMM d, yyyy").
            </MudText>
        </MudPaper>
    }
</MudContainer>

@code {
    private TenantSettingsService.Settings? _settings;
    private string _name = "";
    private string? _location;
    private TenantUnits _units;
    private bool _alertEmailEnabled;
    private bool _publicProfileEnabled;
    private string? _publicContactEmail;
    private string? _error;
    private bool _busy;

    private string PublicFarmUrl => _settings is null
        ? ""
        : $"{Nav.BaseUri.TrimEnd('/')}/pub/{_settings.Slug}";

    private bool HasChanges =>
        _settings is not null &&
        (_name != _settings.Name
         || (_location ?? "") != (_settings.Location ?? "")
         || _units != _settings.Units
         || _alertEmailEnabled != _settings.AlertEmailEnabled
         || _publicProfileEnabled != _settings.PublicProfileEnabled
         || (_publicContactEmail ?? "") != (_settings.PublicContactEmail ?? ""));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _settings = await SettingsApi.GetAsync();
        if (_settings is null) return;
        _name = _settings.Name;
        _location = _settings.Location;
        _units = _settings.Units;
        _alertEmailEnabled = _settings.AlertEmailEnabled;
        _publicProfileEnabled = _settings.PublicProfileEnabled;
        _publicContactEmail = _settings.PublicContactEmail;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var (ok, err, updated) = await SettingsApi.UpdateAsync(new TenantSettingsService.UpdateInput(_name.Trim(), _location?.Trim(), _units, _alertEmailEnabled, _publicProfileEnabled, _publicContactEmail?.Trim()));
            if (!ok)
            {
                _error = err?.Length > 200 ? "Couldn't save. Check your inputs." : (err ?? "Save failed.");
                return;
            }
            _settings = updated;
            Snackbar.Add("Farm settings saved.", Severity.Success);
        }
        finally { _busy = false; }
    }
}
