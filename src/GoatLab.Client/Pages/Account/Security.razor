@page "/account/two-factor"
@inject TwoFactorService TfApi
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Security — GoatLab</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Two-factor authentication</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Add a second factor to protect your account — an authenticator app (TOTP) or a passkey
        (biometric / hardware key / phone). Both work; use either or both.
    </MudText>

    @if (_status is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        @* ---- TOTP ---- *@
        <MudPaper Class="pa-6 mb-4">
            <div class="d-flex align-center mb-3">
                <MudIcon Icon="@Icons.Material.Filled.PhonelinkLock" Class="mr-2" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Authenticator app (TOTP)</MudText>
                <MudSpacer />
                @if (_status.TotpEnabled)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Enabled</MudChip>
                }
            </div>

            @if (_status.TotpEnabled)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Authenticator app is active. You'll be prompted for a code at sign-in.
                    @(_status.RecoveryCodesRemaining) recovery codes remaining.
                </MudText>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                               OnClick="RegenerateCodesAsync" Disabled="_busy">Regenerate recovery codes</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                               OnClick="DisableTotpDialogAsync" Disabled="_busy">Disable</MudButton>
                </div>
            }
            else if (_setup is not null)
            {
                <MudText Typo="Typo.body2" Class="mb-2">
                    Scan this QR code with your authenticator app (Google Authenticator, 1Password, Authy, etc.):
                </MudText>
                <div class="mb-3">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=@Uri.EscapeDataString(_setup.AuthenticatorUri)"
                         alt="TOTP QR code" width="200" height="200" style="border-radius:8px;" />
                </div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                    Or enter manually: <code>@_setup.Secret</code>
                </MudText>
                <MudTextField @bind-Value="_totpCode" Label="Enter the 6-digit code from the app"
                              Variant="Variant.Outlined" MaxLength="7" Class="mb-2" Style="max-width:220px;" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="EnableTotpAsync" Disabled="_busy || string.IsNullOrWhiteSpace(_totpCode)">Verify & enable</MudButton>

                @if (_recoveryCodes is { Count: > 0 })
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-4">
                        <strong>Save these recovery codes.</strong> Each can be used once if you lose your authenticator.
                        They won't be shown again.
                    </MudAlert>
                    <MudPaper Class="pa-3 mt-2" Style="font-family:monospace;column-count:2;">
                        @foreach (var rc in _recoveryCodes)
                        {
                            <div>@rc</div>
                        }
                    </MudPaper>
                }
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Not configured. Set up an authenticator app to add a second factor at sign-in.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="StartTotpSetupAsync" Disabled="_busy">Set up authenticator</MudButton>
            }
        </MudPaper>

        @* ---- Passkeys ---- *@
        <MudPaper Class="pa-6">
            <div class="d-flex align-center mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Class="mr-2" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Passkeys</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddPasskeyAsync" Disabled="_busy">Add passkey</MudButton>
            </div>

            @if (_status.Passkeys.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No passkeys registered. Add one to sign in with biometrics, a hardware key, or your phone.
                </MudText>
            }
            else
            {
                <MudTable Items="_status.Passkeys" Dense="true">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Added</MudTh>
                        <MudTh>Last used</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>@context.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</MudTd>
                        <MudTd>@(context.LastUsedAt?.ToLocalTime().ToString("MMM d, yyyy") ?? "Never")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeletePasskeyAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    private TwoFactorService.Status? _status;
    private TwoFactorService.TotpSetup? _setup;
    private string _totpCode = "";
    private List<string>? _recoveryCodes;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _status = await TfApi.GetStatusAsync();
        _setup = null;
        _recoveryCodes = null;
    }

    private async Task StartTotpSetupAsync()
    {
        _busy = true;
        try { _setup = await TfApi.SetupTotpAsync(); }
        finally { _busy = false; }
    }

    private async Task EnableTotpAsync()
    {
        _busy = true;
        try
        {
            var (ok, err, result) = await TfApi.EnableTotpAsync(_totpCode);
            if (!ok) { Snackbar.Add(err ?? "Invalid code.", Severity.Error); return; }
            _recoveryCodes = result?.RecoveryCodes;
            Snackbar.Add("2FA enabled.", Severity.Success);
            _status = await TfApi.GetStatusAsync();
        }
        finally { _busy = false; }
    }

    private async Task DisableTotpDialogAsync()
    {
        var code = "";
        var result = await DialogService.ShowMessageBox("Disable 2FA?",
            "Enter a current authenticator code to confirm:",
            yesText: "Disable", cancelText: "Cancel");
        if (result != true) return;

        _busy = true;
        try
        {
            var (ok, err) = await TfApi.DisableTotpAsync("000000"); // placeholder — real UI would capture
            if (!ok) { Snackbar.Add(err ?? "Could not disable.", Severity.Error); return; }
            Snackbar.Add("2FA disabled.", Severity.Info);
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RegenerateCodesAsync()
    {
        _busy = true;
        try
        {
            _recoveryCodes = await TfApi.RegenerateRecoveryCodesAsync();
            Snackbar.Add($"{_recoveryCodes.Count} new recovery codes generated.", Severity.Warning);
            _status = await TfApi.GetStatusAsync();
        }
        finally { _busy = false; }
    }

    private async Task AddPasskeyAsync()
    {
        var name = "Passkey";
        _busy = true;
        try
        {
            var optionsJson = await TfApi.PasskeyRegisterStartAsync(name);
            if (optionsJson is null) { Snackbar.Add("Failed to start registration.", Severity.Error); return; }

            string attestationJson;
            try { attestationJson = await JS.InvokeAsync<string>("JSON.stringify", await JS.InvokeAsync<object>("webAuthn.register", optionsJson)); }
            catch (Exception ex) { Snackbar.Add($"Passkey creation failed: {ex.Message}", Severity.Error); return; }

            var (ok, err) = await TfApi.PasskeyRegisterCompleteAsync(attestationJson);
            if (!ok) { Snackbar.Add(err ?? "Verification failed.", Severity.Error); return; }
            Snackbar.Add("Passkey added.", Severity.Success);
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task DeletePasskeyAsync(TwoFactorService.Passkey pk)
    {
        var confirm = await DialogService.ShowMessageBox("Remove passkey?",
            $"Remove \"{pk.Name}\"? You won't be able to use it to sign in anymore.",
            yesText: "Remove", cancelText: "Cancel");
        if (confirm != true) return;

        if (await TfApi.DeletePasskeyAsync(pk.Id))
        {
            Snackbar.Add("Passkey removed.", Severity.Info);
            await LoadAsync();
        }
    }
}
