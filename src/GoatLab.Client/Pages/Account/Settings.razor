@page "/account/settings"
@inject HttpClient Http
@inject AuthService AuthApi
@inject CookieAuthStateProvider AuthState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject PushService PushApi

<PageTitle>Account settings — GoatLab</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Account settings</MudText>

    <MudPaper Class="pa-6 mb-6">
        <MudText Typo="Typo.h6" GutterBottom="true">Download your data</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            Get a ZIP of your profile, memberships, and all records from farms you own
            (JSON format). Satisfies GDPR / CCPA data-portability requests.
        </MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Download"
                   Href="/api/account/export-data">
            Export my data
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-6 mb-6">
        <MudText Typo="Typo.h6" GutterBottom="true">Notification devices</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            Browsers and phones registered to receive GoatLab push notifications.
            Remove a device to stop sending alerts to it.
        </MudText>
        @if (_pushDevices is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_pushDevices.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                No devices registered yet. Visit GoatLab on a phone or laptop and accept the
                "Enable notifications" prompt.
            </MudText>
        }
        else
        {
            <MudList T="GoatLab.Shared.DTOs.PushSubscriptionDto" Dense="true">
                @foreach (var d in _pushDevices)
                {
                    <MudListItem T="GoatLab.Shared.DTOs.PushSubscriptionDto" Icon="@Icons.Material.Filled.Devices">
                        <div class="d-flex align-center" style="gap:12px;">
                            <div style="flex:1;">
                                <div>@(string.IsNullOrEmpty(d.UserAgent) ? "Unknown device" : d.UserAgent)</div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Added @d.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")
                                    @(d.LastUsedAt is null ? "" : $" — last used {d.LastUsedAt.Value.ToLocalTime():MMM d}")
                                </MudText>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="@(() => RemoveDeviceAsync(d.Id))" />
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
        <div class="d-flex gap-2 mt-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.NotificationsActive"
                       OnClick="EnableHereAsync">Enable on this device</MudButton>
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Send"
                       OnClick="SendTestAsync">Send test</MudButton>
        </div>
    </MudPaper>

    <MudPaper Class="pa-6 danger-zone">
        <MudText Typo="Typo.h6" Color="Color.Error" GutterBottom="true">Delete account</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            Marks your account as deleted immediately. If you're the only owner of a farm,
            that farm is also deleted. Hard delete happens 30 days later; until then, your
            data can be recovered by emailing support.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="DeleteAsync" Disabled="_busy">
            Delete my account
        </MudButton>
    </MudPaper>
</MudContainer>

<style>
    .danger-zone { border: 1px solid var(--mud-palette-error); }
</style>

@code {
    private bool _busy;
    private List<GoatLab.Shared.DTOs.PushSubscriptionDto>? _pushDevices;

    protected override Task OnInitializedAsync() => LoadDevicesAsync();

    private async Task LoadDevicesAsync()
    {
        try { _pushDevices = await PushApi.ListSubscriptionsAsync() ?? new(); }
        catch { _pushDevices = new(); }
    }

    private async Task EnableHereAsync()
    {
        try
        {
            var ok = await PushApi.SubscribeAsync();
            if (ok) Snackbar.Add("This device is now subscribed.", Severity.Success);
            else Snackbar.Add("Permission denied or push isn't configured.", Severity.Warning);
        }
        catch (Exception ex) { Snackbar.Add($"Couldn't subscribe: {ex.Message}", Severity.Error); }
        await LoadDevicesAsync();
    }

    private async Task RemoveDeviceAsync(int id)
    {
        try { await PushApi.RemoveSubscriptionAsync(id); }
        catch { Snackbar.Add("Could not remove device.", Severity.Error); return; }
        await LoadDevicesAsync();
    }

    private async Task SendTestAsync()
    {
        try { await PushApi.SendTestAsync(); Snackbar.Add("Test notification queued.", Severity.Info); }
        catch { Snackbar.Add("Couldn't send test.", Severity.Error); }
    }

    private async Task DeleteAsync()
    {
        var result = await DialogService.ShowMessageBox(
            title: "Delete account?",
            markupMessage: new MarkupString(
                "This marks your account as deleted immediately and signs you out.<br/>" +
                "<strong>Farms where you are the sole owner will also be deleted.</strong><br/>" +
                "Hard delete happens in 30 days. This cannot be undone from the app."),
            yesText: "Delete account",
            cancelText: "Cancel");

        if (result != true) return;

        _busy = true;
        try
        {
            var res = await Http.PostAsync("api/account/delete-my-account", content: null);
            if (!res.IsSuccessStatusCode)
            {
                Snackbar.Add("Could not delete account. Try again or contact support.", Severity.Error);
                return;
            }
            Snackbar.Add("Account deleted. Goodbye!", Severity.Info);
            AuthState.NotifyUserChanged(null);
            Nav.NavigateTo("/", forceLoad: true);
        }
        finally { _busy = false; }
    }
}
