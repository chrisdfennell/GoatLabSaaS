@page "/reset-password"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.AuthLayout
@inject AuthService AuthApi
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Reset password — GoatLab</PageTitle>

<MudPaper Elevation="4" Class="pa-8" Style="max-width: 440px; margin: 4rem auto;">
    @if (string.IsNullOrEmpty(_userId) || string.IsNullOrEmpty(_token))
    {
        <MudAlert Severity="Severity.Error">
            This reset link is incomplete or invalid. Request a new one from the
            <MudLink Href="/forgot-password">forgot password</MudLink> page.
        </MudAlert>
    }
    else if (_done)
    {
        <div class="text-center">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
            <MudText Typo="Typo.h5" Class="mt-2 mb-2">Password updated</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth Href="/login">
                Sign in
            </MudButton>
        </div>
    }
    else
    {
        <MudText Typo="Typo.h5" GutterBottom="true">Set a new password</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            At least 8 characters with upper, lower, digit, and symbol.
        </MudText>

        <EditForm Model="this" OnValidSubmit="SubmitAsync">
            <MudTextField @bind-Value="_password" Label="New password" Variant="Variant.Outlined"
                          InputType="InputType.Password" Required="true" Class="mb-3" />
            <MudTextField @bind-Value="_confirm" Label="Confirm password" Variant="Variant.Outlined"
                          InputType="InputType.Password" Required="true" Class="mb-3" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
            }

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                       Color="Color.Primary" FullWidth Disabled="_busy">
                @(_busy ? "Saving…" : "Reset password")
            </MudButton>
        </EditForm>
    }
</MudPaper>

@code {
    private string? _userId;
    private string? _token;
    private string _password = string.Empty;
    private string _confirm = string.Empty;
    private string? _error;
    private bool _busy;
    private bool _done;

    protected override void OnInitialized()
    {
        var query = System.Web.HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        _userId = query["userId"];
        _token = query["token"];
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_password != _confirm) { _error = "Passwords don't match."; return; }
        if (string.IsNullOrEmpty(_userId) || string.IsNullOrEmpty(_token)) return;

        _busy = true;
        try
        {
            var (ok, err) = await AuthApi.ResetPasswordAsync(_userId, _token, _password);
            if (!ok)
            {
                _error = err?.Length > 300 ? "Could not reset password. The link may have expired." : err;
                return;
            }
            _done = true;
            Snackbar.Add("Password updated.", Severity.Success);
        }
        finally { _busy = false; }
    }
}
