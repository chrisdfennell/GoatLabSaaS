@* Shown once after a webhook is created — users need the secret to verify signatures. *@
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            Save this secret now — you'll need it to verify the <code>X-GoatLab-Signature</code> header
            on incoming requests. It won't be shown again.
        </MudAlert>
        <MudTextField Value="@Secret" ReadOnly Variant="Variant.Outlined" Label="Signing secret"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="CopyAsync" />
        <MudText Typo="Typo.body2" Class="mt-3">Verify a payload on your receiver (pseudocode):</MudText>
        <pre style="padding:8px;border-radius:6px;background:rgba(0,0,0,0.06);overflow:auto;">expected = "sha256=" + hex(HMAC-SHA256(secret, raw_body))
if headers["X-GoatLab-Signature"] != expected: reject</pre>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Got it</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string Secret { get; set; } = string.Empty;

    private async Task CopyAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Secret);
            Snackbar.Add("Copied.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Clipboard blocked — select and copy manually.", Severity.Warning);
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
