@page "/terms"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.LandingLayout

<PageTitle>Terms of Service — GoatLab</PageTitle>

<section class="legal-page">
    <div class="container">
        <MudAlert Severity="Severity.Warning" Class="mb-6">
            <strong>Placeholder copy.</strong> Replace this page with terms reviewed by a qualified attorney
            before onboarding paying customers. This scaffold is not legal advice.
        </MudAlert>

        <h1>Terms of Service</h1>
        <p class="effective">Last updated: @DateTime.UtcNow.ToString("MMMM yyyy")</p>

        <h2>1. Acceptance of Terms</h2>
        <p>
            By creating an account on GoatLab (the "Service"), you agree to be bound by these Terms.
            If you do not agree, do not use the Service.
        </p>

        <h2>2. Accounts and Tenants</h2>
        <p>
            You are responsible for all activity under your account, including activity by users you
            invite to your farm (tenant). Keep your credentials confidential.
        </p>

        <h2>3. Plans and Billing</h2>
        <p>
            Paid plans are billed in advance on a recurring basis. Trials convert automatically at the
            end of the trial period unless canceled. Cancelations stop future billing but do not
            refund the current period unless required by law.
        </p>

        <h2>4. Acceptable Use</h2>
        <p>
            Do not use the Service to violate any law, infringe others' rights, distribute malware,
            or attempt to disrupt service availability.
        </p>

        <h2>5. Your Data</h2>
        <p>
            You own the data you enter. We process it to provide the Service and as described in the
            <a href="/privacy">Privacy Policy</a>. You may export or delete your data at any time from
            account settings.
        </p>

        <h2>6. Availability and Warranty</h2>
        <p>
            The Service is provided "as is" without warranty of any kind. We aim for high availability
            but do not guarantee uninterrupted operation.
        </p>

        <h2>7. Limitation of Liability</h2>
        <p>
            To the fullest extent permitted by law, GoatLab's liability for any claim arising from the
            Service is limited to the fees you paid in the twelve months preceding the claim.
        </p>

        <h2>8. Changes</h2>
        <p>
            We may update these Terms. Material changes will be announced via in-app notice or email
            at least 30 days before taking effect for existing subscribers.
        </p>

        <h2>9. Contact</h2>
        <p>
            Questions about these Terms: <a href="mailto:legal@example.com">legal@example.com</a>
        </p>
    </div>
</section>

<style>
    .legal-page { padding: 80px 0; background: #fff; color: #1a2421; }
    .legal-page .container { max-width: 760px; margin: 0 auto; padding: 0 24px; line-height: 1.6; }
    .legal-page h1 { font-size: 32px; margin-bottom: 8px; }
    .legal-page h2 { font-size: 20px; margin-top: 32px; margin-bottom: 8px; }
    .legal-page p { margin-bottom: 12px; }
    .legal-page .effective { color: #6b7a70; font-size: 14px; margin-bottom: 32px; }
    .legal-page a { color: #2e7d32; }
</style>
