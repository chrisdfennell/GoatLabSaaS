@page "/herd/{Id:int}"
@using GoatLab.Shared.DTOs
@inject GoatService GoatSvc
@inject HealthService HealthSvc
@inject MilkService MilkSvc
@inject SalesService SalesSvc
@inject ShowService ShowSvc
@inject CoiService Coi
@inject MateRecommendationsService MateRecs
@inject GoatTransfersService Transfers
@inject CookieAuthStateProvider AuthState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<PageTitle>@(goat?.Name ?? "Goat") — GoatLab</PageTitle>

@if (goat == null)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" />
}
else
{
    @if (goat.IsListedForSale)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.Share" Variant="Variant.Outlined" Dense>
            <strong>Listed for sale.</strong>
            Public link: <MudLink Href="@PublicLink" Target="_blank">@PublicLink</MudLink>
        </MudAlert>
    }

    @* ===== Hero ===== *@
    <div class="page-hero @HeroVariant">
        <div class="goat-form-hero-avatar @GetAvatarClass(goat.Gender)" style="position:relative;z-index:1;">
            @GetInitials(goat.Name)
        </div>
        <div class="page-hero-text">
            <MudText Typo="Typo.overline" Class="page-hero-eyebrow">
                @goat.Status · @goat.Gender @(goat.EarTag != null ? $" · #{goat.EarTag}" : "")
            </MudText>
            <MudText Typo="Typo.h4" Class="page-hero-title">@goat.Name</MudText>
            <MudText Typo="Typo.body2" Class="page-hero-sub">
                @(goat.Breed ?? "Unknown breed")
                @if (goat.DateOfBirth.HasValue) { <span> · @AgeString(goat.DateOfBirth.Value)</span> }
                @if (goat.Pen != null) { <span> · @goat.Pen.Barn?.Name / @goat.Pen.Name</span> }
            </MudText>
            <div class="page-hero-stats">
                <div class="page-hero-stat">
                    <MudText Typo="Typo.h5" Class="page-hero-stat-value">@(latestWeight?.ToString("F1") ?? "—")</MudText>
                    <MudText Class="page-hero-stat-label">Current Weight (lbs)</MudText>
                </div>
                @if (adg.HasValue)
                {
                    <div class="page-hero-stat">
                        <MudText Typo="Typo.h5" Class="page-hero-stat-value">@(adg.Value >= 0 ? "+" : "")@adg.Value.ToString("F2")</MudText>
                        <MudText Class="page-hero-stat-label">Avg Daily Gain (lbs)</MudText>
                    </div>
                }
                @if (lifetimeMilk > 0)
                {
                    <div class="page-hero-stat">
                        <MudText Typo="Typo.h5" Class="page-hero-stat-value">@lifetimeMilk.ToString("F0")</MudText>
                        <MudText Class="page-hero-stat-label">Milk (lbs)</MudText>
                    </div>
                }
                @if (lifetimeRevenue > 0)
                {
                    <div class="page-hero-stat">
                        <MudText Typo="Typo.h5" Class="page-hero-stat-value">$@lifetimeRevenue.ToString("N0")</MudText>
                        <MudText Class="page-hero-stat-label">Revenue</MudText>
                    </div>
                }
            </div>
        </div>
        <div style="position:relative;z-index:1;display:flex;flex-direction:column;gap:8px;">
            @if (MarketReady)
            {
                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large">Market Ready</MudChip>
            }
            @if (withdrawal?.Milk is not null)
            {
                <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.LocalDrink" Size="Size.Large"
                         title="@($"{withdrawal.Milk.Medication} — administered {withdrawal.Milk.Administered.ToLocalTime():MMM d}")">
                    Milk hold until @withdrawal.Milk.EndsAt.ToLocalTime().ToString("MMM d")
                </MudChip>
            }
            @if (withdrawal?.Meat is not null)
            {
                <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.Restaurant" Size="Size.Large"
                         title="@($"{withdrawal.Meat.Medication} — administered {withdrawal.Meat.Administered.ToLocalTime():MMM d}")">
                    Meat hold until @withdrawal.Meat.EndsAt.ToLocalTime().ToString("MMM d")
                </MudChip>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Surface" Style="background:rgba(255,255,255,0.92);color:#1b5e20;"
                       StartIcon="@Icons.Material.Filled.Edit" Href="@($"/herd/{Id}/edit")">Edit</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.AccountTree" Href="@($"/herd/{Id}/pedigree")">Pedigree</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.AttachMoney" Href="@($"/herd/{Id}/pnl")">P&amp;L</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.PictureAsPdf" Href="@($"/herd/report/{Id}")">Report</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.Description"
                       Href="@($"/api/documents/goats/{Id}/pedigree.pdf")" Target="_blank">Pedigree PDF</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.HealthAndSafety"
                       Href="@($"/api/documents/goats/{Id}/health-certificate.pdf")" Target="_blank">Health Cert PDF</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.QrCode2"
                       Href="@($"/api/documents/qr-sheet.pdf?ids={Id}")" Target="_blank">QR Tag</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.SwapHoriz" OnClick="OpenTransferDialog">Transfer to buyer</MudButton>
            <MudButton Variant="Variant.Outlined" Style="border-color:rgba(255,255,255,0.5);color:#fff;"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteGoat">Delete</MudButton>
        </div>
    </div>

    <MudTabs Elevation="0" Rounded ApplyEffectsToContainer PanelClass="pt-4">

        @* ===== PROFILE TAB ===== *@
        <MudTabPanel Text="Profile" Icon="@Icons.Material.Filled.Info">
            <MudGrid>
                <MudItem xs="12" md="7">
                    <MudPaper Class="polished-section" Elevation="0">
                        <div class="polished-section-header">
                            <div class="polished-section-header-title">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" />
                                <div>
                                    <MudText Typo="Typo.h6">Details</MudText>
                                </div>
                            </div>
                        </div>
                        <div class="detail-row"><span class="detail-label">Date of Birth</span><span>@(goat.DateOfBirth?.ToString("MMM d, yyyy") ?? "—")</span></div>
                        @if (goat.DateOfBirth.HasValue)
                        {
                            <div class="detail-row"><span class="detail-label">Age</span><span>@AgeString(goat.DateOfBirth.Value)</span></div>
                        }
                        <div class="detail-row"><span class="detail-label">Sire</span>
                            <span>
                                @if (goat.Sire != null)
                                {
                                    <MudLink Href="@($"/herd/{goat.Sire.Id}")">@goat.Sire.Name</MudLink>
                                }
                                else { <span>—</span> }
                            </span>
                        </div>
                        <div class="detail-row"><span class="detail-label">Dam</span>
                            <span>
                                @if (goat.Dam != null)
                                {
                                    <MudLink Href="@($"/herd/{goat.Dam.Id}")">@goat.Dam.Name</MudLink>
                                }
                                else { <span>—</span> }
                            </span>
                        </div>
                        <div class="detail-row"><span class="detail-label">Pen</span><span>@(goat.Pen != null ? $"{goat.Pen.Barn?.Name} / {goat.Pen.Name}" : "—")</span></div>

                        @if (HasRegistrationInfo)
                        {
                            <MudDivider Class="my-3" />
                            @if (goat.Registry != GoatRegistry.None)
                            {
                                <div class="detail-row"><span class="detail-label">Registry</span>
                                    <span>@goat.Registry @(string.IsNullOrEmpty(goat.RegistrationNumber) ? "" : $"· {goat.RegistrationNumber}")</span>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(goat.RegistrationNumber))
                            {
                                <div class="detail-row"><span class="detail-label">Registration</span><span>@goat.RegistrationNumber</span></div>
                            }
                            @if (!string.IsNullOrEmpty(goat.BreederName))
                            {
                                <div class="detail-row"><span class="detail-label">Breeder</span><span>@goat.BreederName</span></div>
                            }
                            @if (!string.IsNullOrEmpty(goat.TattooLeft) || !string.IsNullOrEmpty(goat.TattooRight))
                            {
                                <div class="detail-row"><span class="detail-label">Tattoo (L / R)</span>
                                    <span>@(goat.TattooLeft ?? "—") / @(goat.TattooRight ?? "—")</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(goat.ScrapieTag))
                            {
                                <div class="detail-row"><span class="detail-label">Scrapie tag</span><span>@goat.ScrapieTag</span></div>
                            }
                            @if (!string.IsNullOrEmpty(goat.Microchip))
                            {
                                <div class="detail-row"><span class="detail-label">Microchip</span><span>@goat.Microchip</span></div>
                            }
                        }

                        @if (!string.IsNullOrWhiteSpace(goat.Bio))
                        {
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@goat.Bio</MudText>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudPaper Class="polished-section" Elevation="0">
                        <div class="polished-section-header">
                            <div class="polished-section-header-title">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" />
                                <div>
                                    <MudText Typo="Typo.h6">Photos</MudText>
                                    <MudText Typo="Typo.body2" Class="section-hint">Upload pics — the first one becomes the primary.</MudText>
                                </div>
                            </div>
                            <MudFileUpload T="IBrowserFile" FilesChanged="UploadPhoto" Accept=".jpg,.jpeg,.png,.webp,.gif">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.CloudUpload"
                                               Disabled="@uploadingPhoto">
                                        @(uploadingPhoto ? "Uploading…" : "Upload")
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>
                        </div>
                        @if (goat.Photos?.Count > 0)
                        {
                            <MudGrid Spacing="2">
                                @foreach (var photo in goat.Photos)
                                {
                                    <MudItem xs="6" sm="4">
                                        <div class="photo-tile">
                                            <img src="@($"/{photo.FilePath}")" alt="@photo.Caption" />
                                            @if (photo.IsPrimary)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                         Icon="@Icons.Material.Filled.Star" Class="photo-tile-primary">Primary</MudChip>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Class="photo-tile-delete"
                                                           OnClick="() => DeletePhoto(photo.Id)" />
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                        else
                        {
                            <div class="inline-empty">
                                <MudIcon Icon="@Icons.Material.Filled.AddAPhoto" />
                                <MudText Typo="Typo.body1">No photos yet</MudText>
                                <MudText Typo="Typo.body2">Upload a portrait or show pic.</MudText>
                            </div>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ===== HEALTH TAB ===== *@
        <MudTabPanel Text="Health" Icon="@Icons.Material.Filled.LocalHospital">
            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" />
                        <div>
                            <MudText Typo="Typo.h6">Medical Records</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">Latest treatments and checkups.</MudText>
                        </div>
                    </div>
                </div>
                @if (medicalRecords?.Count > 0)
                {
                    <div class="record-list">
                        @foreach (var r in medicalRecords.Take(20))
                        {
                            <div class="record-card">
                                <div class="record-card-icon record-card-icon-teal">
                                    <MudIcon Icon="@Icons.Material.Filled.MedicalServices" />
                                </div>
                                <div class="record-card-body">
                                    <div class="record-card-primary">@r.Title</div>
                                    <div class="record-card-secondary">@r.Date.ToString("MMM d, yyyy") · @r.RecordType</div>
                                </div>
                                @if (r.NextDueDate.HasValue && r.NextDueDate.Value <= DateTime.UtcNow)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Overdue</MudChip>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" />
                        <MudText Typo="Typo.body2">No medical records yet.</MudText>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" />
                        <div>
                            <MudText Typo="Typo.h6">FAMACHA Scores</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">Eyelid color — 1 (red, healthy) to 5 (white, anemic).</MudText>
                        </div>
                    </div>
                </div>
                @if (famachaScores?.Count > 0)
                {
                    <div class="record-list">
                        @foreach (var f in famachaScores.Take(10))
                        {
                            <div class="record-card">
                                <div class="record-card-icon @GetFamachaIconBg(f.Score)">
                                    <span>@f.Score</span>
                                </div>
                                <div class="record-card-body">
                                    <div class="record-card-primary">Score @f.Score / 5</div>
                                    <div class="record-card-secondary">@f.Date.ToString("MMM d, yyyy")</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" />
                        <MudText Typo="Typo.body2">No FAMACHA scores logged.</MudText>
                    </div>
                }
            </MudPaper>
        </MudTabPanel>

        @* ===== WEIGHT & MARKET TAB ===== *@
        <MudTabPanel Text="Weight &amp; Market" Icon="@Icons.Material.Filled.Scale">
            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.Scale" />
                        <div>
                            <MudText Typo="Typo.h6">Weight Tracking</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">
                                @if (adg.HasValue)
                                {
                                    <span>ADG: <strong>@(adg.Value >= 0 ? "+" : "")@adg.Value.ToString("F2") lbs/day</strong> over the last @adgDays days</span>
                                }
                                else
                                {
                                    <span>Log at least two weights to see average daily gain.</span>
                                }
                            </MudText>
                        </div>
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="() => showWeightForm = !showWeightForm">
                        @(showWeightForm ? "Close" : "Log Weight")
                    </MudButton>
                </div>

                @if (showWeightForm)
                {
                    <MudPaper Class="pa-4 mb-4" Outlined Style="border-radius:12px;">
                        <MudGrid>
                            <MudItem xs="6" sm="4">
                                <MudNumericField @bind-Value="newWeight.Weight" Label="Weight" Variant="Variant.Outlined"
                                                 Min="0.0" Step="0.5" Adornment="Adornment.End" AdornmentText="lbs" />
                            </MudItem>
                            <MudItem xs="6" sm="4">
                                <MudDatePicker @bind-Date="newWeightDate" Label="Date" Variant="Variant.Outlined" Editable />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="newWeight.Notes" Label="Notes" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                        <div class="d-flex gap-2 mt-3 justify-end">
                            <MudButton Variant="Variant.Text" OnClick="() => showWeightForm = false">Cancel</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveWeight">Save</MudButton>
                        </div>
                    </MudPaper>
                }

                @if (weightSeries.Count > 0 && weightLabels.Length > 1)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@weightSeries" XAxisLabels="@weightLabels"
                              Width="100%" Height="280px"
                              ChartOptions="@(new ChartOptions { YAxisTicks = 1, LineStrokeWidth = 3 })" />
                }

                @if (weights?.Count > 0)
                {
                    <div class="record-list mt-4">
                        @foreach (var w in weights.OrderByDescending(w => w.Date).Take(20))
                        {
                            <div class="record-card">
                                <div class="record-card-icon record-card-icon-green">
                                    <MudIcon Icon="@Icons.Material.Filled.Scale" />
                                </div>
                                <div class="record-card-body">
                                    <div class="record-card-primary">@w.Weight.ToString("F1") lbs</div>
                                    <div class="record-card-secondary">
                                        @w.Date.ToString("MMM d, yyyy")
                                        @if (!string.IsNullOrEmpty(w.Notes)) { <span> · @w.Notes</span> }
                                    </div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="() => DeleteWeight(w.Id)" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Scale" />
                        <MudText Typo="Typo.body1">No weights recorded</MudText>
                        <MudText Typo="Typo.body2">Track weight over time to calculate ADG and monitor market readiness.</MudText>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" />
                        <div>
                            <MudText Typo="Typo.h6">Market Readiness</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">
                                Configurable target weight for meat goats — typical market weight is 60-100 lbs.
                            </MudText>
                        </div>
                    </div>
                </div>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="marketTargetLbs" Label="Target Weight"
                                         Variant="Variant.Outlined" Min="10" Max="500" Step="5"
                                         Adornment="Adornment.End" AdornmentText="lbs" />
                    </MudItem>
                    <MudItem xs="12" sm="6" Class="d-flex align-center">
                        @if (latestWeight.HasValue)
                        {
                            var pct = (latestWeight.Value / marketTargetLbs) * 100;
                            <div style="flex:1;">
                                <MudText Typo="Typo.body2" Class="mb-1">
                                    <strong>@latestWeight.Value.ToString("F1") / @marketTargetLbs lbs</strong>
                                    (@pct.ToString("F0")%)
                                </MudText>
                                <MudProgressLinear Value="@Math.Min(100, pct)"
                                                   Color="@(pct >= 100 ? Color.Success : pct >= 80 ? Color.Info : Color.Primary)"
                                                   Rounded Style="height:10px;" />
                                @if (pct >= 100)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Success" Class="mt-1">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Style="vertical-align:text-bottom;" />
                                        Ready for market
                                    </MudText>
                                }
                                else if (adg.HasValue && adg.Value > 0)
                                {
                                    var daysToTarget = (marketTargetLbs - latestWeight.Value) / adg.Value;
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        ~@((int)daysToTarget) days to target at current ADG
                                    </MudText>
                                }
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Log a weight to see progress toward target.</MudText>
                        }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>

        @* ===== MILK TAB ===== *@
        @if (goat.Gender == Gender.Female)
        {
            <MudTabPanel Text="Milk" Icon="@Icons.Material.Filled.WaterDrop">
                <MudPaper Class="polished-section" Elevation="0">
                    <div class="polished-section-header">
                        <div class="polished-section-header-title">
                            <MudIcon Icon="@Icons.Material.Filled.Insights" />
                            <div>
                                <MudText Typo="Typo.h6">Production Trend</MudText>
                                <MudText Typo="Typo.body2" Class="section-hint">Last 30 days for @goat.Name.</MudText>
                            </div>
                        </div>
                    </div>
                    @if (milkTrendSeries.Count > 0 && milkTrendLabels.Length > 0)
                    {
                        <MudChart ChartType="ChartType.Line" ChartSeries="@milkTrendSeries" XAxisLabels="@milkTrendLabels"
                                  Width="100%" Height="260px"
                                  ChartOptions="@(new ChartOptions { YAxisTicks = 1, LineStrokeWidth = 3 })" />
                    }
                    else
                    {
                        <div class="inline-empty">
                            <MudIcon Icon="@Icons.Material.Filled.WaterDrop" />
                            <MudText Typo="Typo.body2">No recent milk logs to graph.</MudText>
                        </div>
                    }
                </MudPaper>

                <MudPaper Class="polished-section" Elevation="0">
                    <div class="polished-section-header">
                        <div class="polished-section-header-title">
                            <MudIcon Icon="@Icons.Material.Filled.EventNote" />
                            <div>
                                <MudText Typo="Typo.h6">Lactations</MudText>
                                <MudText Typo="Typo.body2" Class="section-hint">
                                    Freshening-to-dry-off cycles with 305-day projections and DHIR test days.
                                </MudText>
                            </div>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="StartLactation">Start lactation</MudButton>
                    </div>

                    @if (lactations == null)
                    {
                        <MudProgressLinear Indeterminate Color="Color.Primary" />
                    }
                    else if (!lactations.Any())
                    {
                        <div class="inline-empty">
                            <MudIcon Icon="@Icons.Material.Filled.EventNote" />
                            <MudText Typo="Typo.body1">No lactations recorded</MudText>
                            <MudText Typo="Typo.body2">Record a kidding to auto-start one, or add manually.</MudText>
                        </div>
                    }
                    else
                    {
                        <div style="display:flex;flex-direction:column;gap:14px;">
                            @foreach (var lac in lactations)
                            {
                                var accent = lac.IsActive ? "#2e7d32" : "#607d8b";
                                <MudPaper Outlined Class="pa-3" Style="@($"border-left:4px solid {accent};")">
                                    <div class="d-flex justify-space-between align-center flex-wrap">
                                        <div>
                                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">
                                                Lactation #@lac.LactationNumber
                                                @if (lac.IsActive)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled" Class="ml-2">Active</MudChip>
                                                }
                                                else
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="ml-2">Closed</MudChip>
                                                }
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Fresh @lac.FreshenDate.ToString("MMM d, yyyy")
                                                @if (lac.DryOffDate.HasValue) { <span> · Dry off @lac.DryOffDate.Value.ToString("MMM d, yyyy")</span> }
                                                · DIM @lac.DaysInMilk
                                            </MudText>
                                        </div>
                                        <div class="d-flex" style="gap:6px;">
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                                       StartIcon="@Icons.Material.Filled.Add"
                                                       OnClick="@(() => AddTestDay(lac))">Test day</MudButton>
                                            @if (lac.IsActive)
                                            {
                                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                                           StartIcon="@Icons.Material.Filled.EventBusy"
                                                           OnClick="@(() => DryOff(lac))">Dry off</MudButton>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           OnClick="@(() => DeleteLactation(lac.Id))" />
                                        </div>
                                    </div>

                                    <MudGrid Class="mt-2" Spacing="1">
                                        <MudItem xs="6" sm="3">
                                            <div class="lac-stat">
                                                <div class="lac-stat-label">Total</div>
                                                <div class="lac-stat-value">@lac.TotalMilkLbs.ToString("F0") lbs</div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <div class="lac-stat">
                                                <div class="lac-stat-label">Avg / day</div>
                                                <div class="lac-stat-value">@lac.AvgDailyLbs.ToString("F1") lbs</div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <div class="lac-stat">
                                                <div class="lac-stat-label">Peak</div>
                                                <div class="lac-stat-value">
                                                    @lac.PeakLbs.ToString("F1") lbs
                                                    @if (lac.PeakDim > 0) { <span style="font-size:0.75rem;color:#888;"> (DIM @lac.PeakDim)</span> }
                                                </div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <div class="lac-stat">
                                                <div class="lac-stat-label">305-day proj.</div>
                                                <div class="lac-stat-value">
                                                    @(lac.Projected305.HasValue ? lac.Projected305.Value.ToString("F0") + " lbs" : "—")
                                                </div>
                                            </div>
                                        </MudItem>
                                    </MudGrid>

                                    @if (lac.TestDays.Any())
                                    {
                                        <MudDivider Class="my-3" />
                                        <MudText Typo="Typo.caption" Style="text-transform:uppercase;letter-spacing:1px;color:#888;font-weight:600;">Test days</MudText>
                                        <div style="display:flex;flex-direction:column;gap:4px;margin-top:6px;">
                                            @foreach (var td in lac.TestDays)
                                            {
                                                <div class="test-day-row">
                                                    <span class="test-day-date">@td.TestDate.ToString("MMM d") · DIM @td.Dim</span>
                                                    <span class="test-day-total">@td.TotalLbs.ToString("F1") lbs</span>
                                                    @if (td.ButterfatPercent.HasValue)
                                                    {
                                                        <span class="test-day-chip">BF @td.ButterfatPercent.Value.ToString("F1")%</span>
                                                    }
                                                    @if (td.ProteinPercent.HasValue)
                                                    {
                                                        <span class="test-day-chip">PR @td.ProteinPercent.Value.ToString("F1")%</span>
                                                    }
                                                    @if (td.SomaticCellCount.HasValue)
                                                    {
                                                        var sccColor = td.SomaticCellCount > 400 ? "#c62828" : td.SomaticCellCount > 200 ? "#ef6c00" : "#2e7d32";
                                                        <span class="test-day-chip" style="@($"background:{sccColor};color:#fff;")">SCC @td.SomaticCellCount</span>
                                                    }
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   OnClick="@(() => DeleteTestDay(td.Id))" />
                                                </div>
                                            }
                                        </div>
                                    }
                                </MudPaper>
                            }
                        </div>
                    }
                </MudPaper>

                <MudPaper Class="polished-section" Elevation="0">
                    <div class="polished-section-header">
                        <div class="polished-section-header-title">
                            <MudIcon Icon="@Icons.Material.Filled.WaterDrop" />
                            <div>
                                <MudText Typo="Typo.h6">Milk History</MudText>
                                <MudText Typo="Typo.body2" Class="section-hint">
                                    @((milkLogs?.Count ?? 0)) entries · @lifetimeMilk.ToString("F1") lbs total
                                </MudText>
                            </div>
                        </div>
                    </div>
                    @if (milkLogs?.Count > 0)
                    {
                        <div class="record-list">
                            @foreach (var m in milkLogs.Take(30))
                            {
                                <div class="record-card">
                                    <div class="record-card-icon record-card-icon-blue">
                                        <MudIcon Icon="@Icons.Material.Filled.WaterDrop" />
                                    </div>
                                    <div class="record-card-body">
                                        <div class="record-card-primary">@m.Amount.ToString("F1") lbs</div>
                                        <div class="record-card-secondary">
                                            @m.Date.ToString("MMM d, yyyy")
                                            @if (!string.IsNullOrEmpty(m.Notes)) { <span> · @m.Notes</span> }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="inline-empty">
                            <MudIcon Icon="@Icons.Material.Filled.WaterDrop" />
                            <MudText Typo="Typo.body2">No milk logs for this goat.</MudText>
                        </div>
                    }
                </MudPaper>
            </MudTabPanel>
        }

        @* ===== SALES TAB ===== *@
        <MudTabPanel Text="Sales" Icon="@Icons.Material.Filled.AttachMoney">
            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                        <div>
                            <MudText Typo="Typo.h6">Sale History</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">
                                Every sale tied to @goat.Name · total <strong>$@lifetimeRevenue.ToString("N2")</strong>
                            </MudText>
                        </div>
                    </div>
                </div>
                @if (sales?.Count > 0)
                {
                    <div class="record-list">
                        @foreach (var s in sales)
                        {
                            <div class="record-card">
                                <div class="record-card-icon @GetSaleTypeIconBg(s.SaleType)">
                                    <MudIcon Icon="@GetSaleTypeIcon(s.SaleType)" />
                                </div>
                                <div class="record-card-body">
                                    <div class="record-card-primary">@(string.IsNullOrWhiteSpace(s.Description) ? s.SaleType.ToString() : s.Description)</div>
                                    <div class="record-card-secondary">
                                        @s.SaleDate.ToString("MMM d, yyyy")
                                        @if (s.Customer != null) { <span> · @s.Customer.Name</span> }
                                    </div>
                                </div>
                                <MudText Class="record-card-amount record-card-amount-income">$@s.Amount.ToString("F2")</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetPaymentColor(s.PaymentStatus)" Variant="Variant.Filled">
                                    @s.PaymentStatus
                                </MudChip>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                        <MudText Typo="Typo.body2">No sales recorded for @goat.Name yet.</MudText>
                    </div>
                }
            </MudPaper>
        </MudTabPanel>

        @* ===== SHOWS TAB ===== *@
        <MudTabPanel Text="Shows" Icon="@Icons.Material.Filled.EmojiEvents">
            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        <div>
                            <MudText Typo="Typo.h6">Show record</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">
                                @ShowRecords.Count show@(ShowRecords.Count == 1 ? "" : "s")
                                @if (FirstPlacings > 0) { <span> · @FirstPlacings first place@(FirstPlacings == 1 ? "" : "s")</span> }
                            </MudText>
                        </div>
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddShow">Add show</MudButton>
                </div>

                @if (!ShowRecords.Any())
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        <MudText Typo="Typo.body1">No show results yet</MudText>
                        <MudText Typo="Typo.body2">Log placings, class size, and judge comments.</MudText>
                    </div>
                }
                else
                {
                    <div class="record-list">
                        @foreach (var s in ShowRecords)
                        {
                            <div class="record-card">
                                <div class="record-card-icon @(s.Placing == 1 ? "record-card-icon-gold" : "record-card-icon-blue")">
                                    <MudIcon Icon="@(s.Placing == 1 ? Icons.Material.Filled.EmojiEvents : Icons.Material.Filled.MilitaryTech)" />
                                </div>
                                <div class="record-card-body">
                                    <div class="record-card-primary">
                                        @s.ShowName
                                        @if (s.Placing.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="@PlacingColor(s.Placing.Value)" Variant="Variant.Filled" Class="ml-2">
                                                @PlacingLabel(s.Placing.Value)@(s.ClassSize.HasValue ? $" / {s.ClassSize}" : "")
                                            </MudChip>
                                        }
                                        @if (!string.IsNullOrEmpty(s.Awards))
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ml-1">
                                                @s.Awards
                                            </MudChip>
                                        }
                                    </div>
                                    <div class="record-card-secondary">
                                        @s.ShowDate.ToString("MMM d, yyyy")
                                        @if (!string.IsNullOrEmpty(s.Class)) { <span> · @s.Class</span> }
                                        @if (!string.IsNullOrEmpty(s.Judge)) { <span> · Judge @s.Judge</span> }
                                        @if (!string.IsNullOrEmpty(s.Location)) { <span> · @s.Location</span> }
                                    </div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="() => DeleteShow(s.Id)" />
                            </div>
                        }
                    </div>
                }
            </MudPaper>

            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" />
                        <div>
                            <MudText Typo="Typo.h6">Linear appraisal</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">@Appraisals.Count score@(Appraisals.Count == 1 ? "" : "s") on file.</MudText>
                        </div>
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddAppraisal">Add appraisal</MudButton>
                </div>

                @if (!Appraisals.Any())
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" />
                        <MudText Typo="Typo.body1">No appraisals yet</MudText>
                        <MudText Typo="Typo.body2">4 category scores + final composite + classification.</MudText>
                    </div>
                }
                else
                {
                    <MudGrid>
                        @foreach (var a in Appraisals)
                        {
                            <MudItem xs="12" md="6">
                                <MudPaper Outlined Class="pa-3" Style="@($"border-left:4px solid {ClassColor(a.Classification)};")">
                                    <div class="d-flex justify-space-between align-center">
                                        <div>
                                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">
                                                @(a.FinalScore?.ToString() ?? "—")
                                                @if (a.Classification.HasValue)
                                                {
                                                    <span style="color:#888;font-weight:500;font-size:0.9rem;"> · @ClassLabel(a.Classification.Value)</span>
                                                }
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @a.AppraisalDate.ToString("MMM d, yyyy")
                                                @if (!string.IsNullOrEmpty(a.Appraiser)) { <span> · @a.Appraiser</span> }
                                            </MudText>
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       OnClick="() => DeleteAppraisal(a.Id)" />
                                    </div>
                                    <MudGrid Class="mt-2" Spacing="1">
                                        <MudItem xs="6"><MudText Typo="Typo.caption">GA: <strong>@(a.GeneralAppearance?.ToString() ?? "—")</strong></MudText></MudItem>
                                        <MudItem xs="6"><MudText Typo="Typo.caption">DC: <strong>@(a.DairyCharacter?.ToString() ?? "—")</strong></MudText></MudItem>
                                        <MudItem xs="6"><MudText Typo="Typo.caption">BC: <strong>@(a.BodyCapacity?.ToString() ?? "—")</strong></MudText></MudItem>
                                        <MudItem xs="6"><MudText Typo="Typo.caption">MS: <strong>@(a.MammarySystem?.ToString() ?? "—")</strong></MudText></MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudPaper>
        </MudTabPanel>

        @* ===== INBREEDING TAB ===== *@
        @if (CoiEnabled)
        {
            <MudTabPanel Text="Inbreeding" Icon="@Icons.Material.Filled.Biotech">
                <MudPaper Class="polished-section" Elevation="0">
                    <div class="polished-section-header">
                        <div class="polished-section-header-title">
                            <MudIcon Icon="@Icons.Material.Filled.Biotech" />
                            <div>
                                <MudText Typo="Typo.h6">Wright's coefficient of inbreeding</MudText>
                                <MudText Typo="Typo.body2" Class="section-hint">
                                    Probability that the two alleles at a locus are identical by descent. Walks 6 generations of pedigree.
                                </MudText>
                            </div>
                        </div>
                    </div>

                    @if (coiLoading)
                    {
                        <MudProgressLinear Indeterminate Color="Color.Primary" />
                    }
                    else if (coiResult is null)
                    {
                        <div class="inline-empty">
                            <MudIcon Icon="@Icons.Material.Filled.Pets" />
                            <MudText Typo="Typo.body1">No COI to compute</MudText>
                            <MudText Typo="Typo.body2">This goat needs both a sire and a dam recorded before COI can be calculated.</MudText>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-center gap-3 mb-4">
                            <MudChip T="string" Size="Size.Large" Color="@CoiColor(coiResult.Coi)" Variant="Variant.Filled">
                                COI: @FormatCoi(coiResult.Coi)
                            </MudChip>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @CoiDescription(coiResult.Coi)
                            </MudText>
                        </div>
                        @if (coiResult.CommonAncestors.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Common ancestors</MudText>
                            <MudSimpleTable Dense Hover Bordered="false" Striped>
                                <thead>
                                    <tr><th>Ancestor</th><th>Sire path</th><th>Dam path</th><th>Contribution</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in coiResult.CommonAncestors.Take(10))
                                    {
                                        <tr>
                                            <td><MudLink Href="@($"/herd/{a.GoatId}")">@(a.Name ?? $"#{a.GoatId}")</MudLink></td>
                                            <td>@a.SirePathLength</td>
                                            <td>@a.DamPathLength</td>
                                            <td>@FormatCoi(a.Contribution)</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    }

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.subtitle2" Class="mb-2">What if I bred @goat.Name with…</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="8">
                            <MudSelect T="int?" @bind-Value="selectedMateId" Label="Pick a mate" Variant="Variant.Outlined"
                                       Clearable AnchorOrigin="Origin.BottomCenter">
                                @foreach (var m in MateCandidates)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)m.Id)">@m.Name @(m.EarTag is not null ? $"#{m.EarTag}" : "")</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth
                                       OnClick="ComputeMateCoi" Disabled="@(selectedMateId is null || mateCoiLoading)">
                                @(mateCoiLoading ? "Computing…" : "Project offspring COI")
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    @if (mateCoiResult is not null)
                    {
                        <div class="d-flex align-center gap-3 mt-3">
                            <MudChip T="string" Size="Size.Large" Color="@CoiColor(mateCoiResult.Coi)" Variant="Variant.Filled">
                                Projected: @FormatCoi(mateCoiResult.Coi)
                            </MudChip>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @CoiDescription(mateCoiResult.Coi)
                            </MudText>
                        </div>
                    }
                </MudPaper>
            </MudTabPanel>
        }

        @* ===== MATE RECOMMENDATIONS TAB (does only, CoI plan gate shared with Inbreeding) ===== *@
        @if (CoiEnabled && goat.Gender == Gender.Female)
        {
            <MudTabPanel Text="Mate matches" Icon="@Icons.Material.Filled.Favorite">
                <MudPaper Class="polished-section" Elevation="0">
                    <div class="polished-section-header">
                        <div class="polished-section-header-title">
                            <MudIcon Icon="@Icons.Material.Filled.Favorite" Style="color:#c2185b;" />
                            <div>
                                <MudText Typo="Typo.h6">Recommended sires for @goat.Name</MudText>
                                <MudText Typo="Typo.body2" Class="section-hint">
                                    Composite score blends projected COI (70 pts) with proven production:
                                    live-birth rate, litter size, and daughters' milk output (30 pts).
                                </MudText>
                            </div>
                        </div>
                    </div>

                    @if (mateRecsLoading)
                    {
                        <MudProgressLinear Indeterminate Color="Color.Primary" />
                    }
                    else if (mateRecs is null || mateRecs.Count == 0)
                    {
                        <div class="inline-empty">
                            <MudIcon Icon="@Icons.Material.Filled.Pets" />
                            <MudText Typo="Typo.body1">No eligible sires</MudText>
                            <MudText Typo="Typo.body2">Add at least one non-external male goat to your herd to get mate recommendations.</MudText>
                        </div>
                    }
                    else
                    {
                        <MudSimpleTable Dense Hover Striped>
                            <thead>
                                <tr>
                                    <th style="width:30px;"></th>
                                    <th>Sire</th>
                                    <th>Score</th>
                                    <th>Proj. COI</th>
                                    <th>Kiddings</th>
                                    <th>Live-birth</th>
                                    <th>Litter</th>
                                    <th>Daughter milk</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < mateRecs.Count; i++)
                                {
                                    var r = mateRecs[i];
                                    var rank = i + 1;
                                    <tr style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo($"/herd/{r.BuckId}"))">
                                        <td>
                                            @if (rank == 1)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color:#f9a825;" Size="Size.Small" />
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">#@rank</MudText>
                                            }
                                        </td>
                                        <td>
                                            <MudText Typo="Typo.body2" Style="font-weight:600;">@r.BuckName</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(r.EarTag is not null ? $"#{r.EarTag} · " : "")@(r.Breed ?? "—")
                                            </MudText>
                                        </td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Color="@ScoreColor(r.CompositeScore)" Variant="Variant.Filled">
                                                @r.CompositeScore.ToString("F0")
                                            </MudChip>
                                        </td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Color="@CoiColor(r.ProjectedCoi)" Variant="Variant.Outlined">
                                                @FormatCoi(r.ProjectedCoi)
                                            </MudChip>
                                        </td>
                                        <td>@r.KiddingsSired</td>
                                        <td>@(r.LiveBirthRate is double lbr ? (lbr * 100).ToString("F0") + "%" : "—")</td>
                                        <td>@(r.AvgLitterSize is double ls ? ls.ToString("F1") : "—")</td>
                                        <td>@(r.DaughterMilkDailyAvgLbs is double milk ? milk.ToString("F1") + " lb/d" : "—")</td>
                                    </tr>
                                    <tr>
                                        <td></td>
                                        <td colspan="7" style="padding-top:0;padding-bottom:12px;">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@r.Rationale</MudText>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudPaper>
            </MudTabPanel>
        }

        @* ===== DOCUMENTS TAB ===== *@
        <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.Folder">
            <MudPaper Class="polished-section" Elevation="0">
                <div class="polished-section-header">
                    <div class="polished-section-header-title">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" />
                        <div>
                            <MudText Typo="Typo.h6">Documents</MudText>
                            <MudText Typo="Typo.body2" Class="section-hint">
                                Registration papers, test results, bills of sale, CVIs, etc.
                            </MudText>
                        </div>
                    </div>
                </div>

                <MudGrid>
                    <MudItem xs="12" sm="5">
                        <MudTextField @bind-Value="docTitle" Label="Document title" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudSelect T="string" @bind-Value="docType" Label="Type" Variant="Variant.Outlined" Clearable>
                            @foreach (var t in DocumentTypes)
                            {
                                <MudSelectItem Value="@t">@t</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="3" Class="d-flex align-end">
                        <MudFileUpload T="IBrowserFile" FilesChanged="UploadDocument"
                                       Accept=".pdf,.jpg,.jpeg,.png,.webp,.heic,.doc,.docx">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth
                                           StartIcon="@Icons.Material.Filled.CloudUpload"
                                           Disabled="@(uploadingDoc || string.IsNullOrWhiteSpace(docTitle))">
                                    @(uploadingDoc ? "Uploading…" : "Upload")
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                    </MudItem>
                </MudGrid>

                @if (goat.Documents?.Count > 0)
                {
                    <MudDivider Class="my-3" />
                    <div class="record-list">
                        @foreach (var d in goat.Documents.OrderByDescending(x => x.UploadedAt))
                        {
                            <div class="record-card">
                                <div class="record-card-icon record-card-icon-blue">
                                    <MudIcon Icon="@DocumentIcon(d.FilePath)" />
                                </div>
                                <div class="record-card-body">
                                    <div class="record-card-primary">
                                        <a href="@($"/{d.FilePath}")" target="_blank" style="text-decoration:none;color:inherit;">
                                            @d.Title
                                        </a>
                                    </div>
                                    <div class="record-card-secondary">
                                        @d.UploadedAt.ToString("MMM d, yyyy")
                                        @if (!string.IsNullOrEmpty(d.DocumentType)) { <span> · @d.DocumentType</span> }
                                    </div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                               Href="@($"/{d.FilePath}")" Target="_blank" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               OnClick="() => DeleteDocument(d.Id)" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="inline-empty">
                        <MudIcon Icon="@Icons.Material.Filled.FolderOpen" />
                        <MudText Typo="Typo.body1">No documents attached</MudText>
                        <MudText Typo="Typo.body2">Upload registration papers, disease test results, purchase agreements, health certificates.</MudText>
                    </div>
                }
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
}

