@code {
    [Parameter] public int Id { get; set; }

    private Goat? goat;
    private List<MedicalRecord>? medicalRecords;
    private List<WeightRecord>? weights;
    private List<FamachaScore>? famachaScores;
    private List<MilkLog>? milkLogs;
    private List<Sale>? sales;
    private List<ShowRecord>? showRecordsList;
    private List<LinearAppraisal>? appraisals;
    private List<LactationSummary>? lactations;
    private WithdrawalStatus? withdrawal;

    private bool showWeightForm;
    private WeightRecord newWeight = new();
    private DateTime? newWeightDate = DateTime.Today;
    private bool uploadingPhoto;

    // Documents tab state
    private string? docTitle;
    private string? docType;
    private bool uploadingDoc;
    private static readonly string[] DocumentTypes = { "Registration", "Health certificate", "Test result", "Bill of sale", "Pedigree", "Show papers", "Other" };

    // Inbreeding tab state
    private CoiResultDto? coiResult;
    private bool coiLoading;
    private List<Goat> herdGoats = new();
    private int? selectedMateId;
    private CoiResultDto? mateCoiResult;
    private bool mateCoiLoading;

    // Mate recommendations tab state — lazy loaded on tab click.
    private List<MateRecommendationDto>? mateRecs;
    private bool mateRecsLoading;
    private bool mateRecsLoaded;

    private bool CoiEnabled => AuthState.CurrentUser?.EnabledFeatures?
        .Contains("CoiCalculator", StringComparer.OrdinalIgnoreCase) == true;

    private IEnumerable<Goat> MateCandidates =>
        herdGoats.Where(g => g.Id != Id
            && goat is not null
            && g.Gender != goat.Gender
            && g.Gender != Gender.Wether);

    private static MudBlazor.Color CoiColor(double coi) => coi switch
    {
        < 0.0625 => MudBlazor.Color.Success,
        < 0.125 => MudBlazor.Color.Warning,
        _ => MudBlazor.Color.Error,
    };

    private static MudBlazor.Color ScoreColor(double score) => score switch
    {
        >= 80 => MudBlazor.Color.Success,
        >= 60 => MudBlazor.Color.Primary,
        >= 40 => MudBlazor.Color.Warning,
        _ => MudBlazor.Color.Error,
    };

    private static string FormatCoi(double coi) => $"{(coi * 100):F2}%";

    private async Task OpenTransferDialog()
    {
        if (goat is null) return;
        var parameters = new DialogParameters
        {
            [nameof(TransferGoatDialog.GoatId)] = Id,
            [nameof(TransferGoatDialog.GoatName)] = goat.Name,
        };
        await Dialog.ShowAsync<TransferGoatDialog>("Transfer goat to buyer", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
    }

    private async Task EnsureMateRecommendations()
    {
        if (mateRecsLoaded || mateRecsLoading) return;
        mateRecsLoading = true;
        try
        {
            mateRecs = await MateRecs.GetForDoeAsync(Id, 10) ?? new();
            mateRecsLoaded = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load mate recommendations: {ex.Message}", Severity.Warning);
        }
        finally
        {
            mateRecsLoading = false;
        }
    }

    private string PublicLink
    {
        get
        {
            var user = AuthState.CurrentUser;
            var slug = user?.Memberships?.FirstOrDefault(m => m.TenantId == user.CurrentTenantId)?.Slug;
            return $"{Nav.BaseUri.TrimEnd('/')}/pub/{slug}/{Id}";
        }
    }

    private static string CoiDescription(double coi) => coi switch
    {
        < 0.0625 => "Within breeder-safe range (<6.25%).",
        < 0.125 => "Elevated. Watch for reduced vigor in offspring (6.25–12.5%).",
        < 0.25 => "High. Equivalent to first-cousin or closer mating.",
        _ => "Very high — equivalent to full-sib or parent-offspring mating.",
    };

    // Computed for tabs
    private List<ShowRecord> ShowRecords => showRecordsList ?? new();
    private List<LinearAppraisal> Appraisals => appraisals ?? new();
    private int FirstPlacings => ShowRecords.Count(s => s.Placing == 1);
    private bool HasRegistrationInfo => goat != null &&
        (goat.Registry != GoatRegistry.None
         || !string.IsNullOrEmpty(goat.RegistrationNumber)
         || !string.IsNullOrEmpty(goat.BreederName)
         || !string.IsNullOrEmpty(goat.TattooLeft)
         || !string.IsNullOrEmpty(goat.TattooRight)
         || !string.IsNullOrEmpty(goat.ScrapieTag)
         || !string.IsNullOrEmpty(goat.Microchip));

    private double marketTargetLbs = 80;

    private List<ChartSeries> weightSeries = new();
    private string[] weightLabels = Array.Empty<string>();
    private List<ChartSeries> milkTrendSeries = new();
    private string[] milkTrendLabels = Array.Empty<string>();

    private double? latestWeight => weights?.OrderByDescending(w => w.Date).FirstOrDefault()?.Weight;
    private double? adg;
    private int adgDays;
    private double lifetimeMilk => milkLogs?.Sum(m => m.Amount) ?? 0;
    private decimal lifetimeRevenue => sales?.Where(s => s.PaymentStatus == PaymentStatus.PaidInFull).Sum(s => s.Amount) ?? 0m;
    private bool MarketReady => latestWeight.HasValue && latestWeight.Value >= marketTargetLbs;

    private string HeroVariant => goat?.Gender switch
    {
        Gender.Female => "page-hero-pink",
        Gender.Male => "page-hero-blue",
        Gender.Wether => "page-hero-purple",
        _ => "page-hero-green"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        goat = await GoatSvc.GetAsync(Id);

        var medTask = HealthSvc.GetRecordsAsync(Id);
        var weightTask = HealthSvc.GetWeightsAsync(Id);
        var famachaTask = HealthSvc.GetFamachaAsync(Id);
        var milkTask = MilkSvc.GetAllAsync(goatId: Id);
        var salesTask = SalesSvc.GetAllAsync(goatId: Id);
        var milkTrendTask = MilkSvc.GetTrendsAsync(goatId: Id, days: 30);
        var showTask = ShowSvc.GetShowsAsync(Id);
        var appraisalTask = ShowSvc.GetAppraisalsAsync(Id);
        var lactationTask = MilkSvc.GetLactationsAsync(Id);
        var withdrawalTask = HealthSvc.GetWithdrawalAsync(Id);

        await Task.WhenAll(medTask, weightTask, famachaTask, milkTask, salesTask, milkTrendTask, showTask, appraisalTask, lactationTask, withdrawalTask);

        withdrawal = withdrawalTask.Result;

        medicalRecords = medTask.Result;
        weights = weightTask.Result;
        famachaScores = famachaTask.Result;
        milkLogs = milkTask.Result;
        sales = salesTask.Result;
        showRecordsList = showTask.Result;
        appraisals = appraisalTask.Result;
        lactations = lactationTask.Result;

        RebuildWeightChart();
        RebuildMilkTrendChart(milkTrendTask.Result);
        ComputeAdg();

        if (CoiEnabled)
        {
            _ = LoadCoiAsync();
            if (goat is { Gender: Gender.Female })
            {
                _ = EnsureMateRecommendations();
            }
        }
    }

    private async Task LoadCoiAsync()
    {
        coiLoading = true;
        try
        {
            var coiTask = goat is { SireId: not null, DamId: not null }
                ? Coi.GetForGoatAsync(Id)
                : Task.FromResult<CoiResultDto?>(null);
            var herdTask = GoatSvc.GetAllAsync(includeExternal: true);
            await Task.WhenAll(coiTask, herdTask);
            coiResult = coiTask.Result;
            herdGoats = herdTask.Result ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load COI: {ex.Message}", Severity.Warning);
        }
        finally
        {
            coiLoading = false;
            StateHasChanged();
        }
    }

    private async Task ComputeMateCoi()
    {
        if (selectedMateId is null || goat is null) return;
        mateCoiLoading = true;
        try
        {
            var sireId = goat.Gender == Gender.Male ? Id : selectedMateId.Value;
            var damId = goat.Gender == Gender.Male ? selectedMateId.Value : Id;
            mateCoiResult = await Coi.GetForMateAsync(sireId, damId);
        }
        finally
        {
            mateCoiLoading = false;
            StateHasChanged();
        }
    }

    private void RebuildWeightChart()
    {
        if (weights == null || weights.Count == 0)
        {
            weightSeries = new();
            weightLabels = Array.Empty<string>();
            return;
        }
        var ordered = weights.OrderBy(w => w.Date).ToList();
        weightLabels = ordered.Select(w => w.Date.ToString("M/d")).ToArray();
        weightSeries = new()
        {
            new ChartSeries { Name = "Weight (lbs)", Data = ordered.Select(w => w.Weight).ToArray() }
        };
    }

    private void RebuildMilkTrendChart(List<MilkTrend>? trends)
    {
        if (trends == null || trends.Count == 0)
        {
            milkTrendSeries = new();
            milkTrendLabels = Array.Empty<string>();
            return;
        }
        milkTrendLabels = trends.Select(t => t.Date.ToString("M/d")).ToArray();
        milkTrendSeries = new()
        {
            new ChartSeries { Name = "Milk (lbs)", Data = trends.Select(t => t.TotalLbs).ToArray() }
        };
    }

    private void ComputeAdg()
    {
        if (weights == null || weights.Count < 2) { adg = null; return; }
        var ordered = weights.OrderBy(w => w.Date).ToList();
        var first = ordered.First();
        var last = ordered.Last();
        var days = (last.Date - first.Date).TotalDays;
        if (days <= 0) { adg = null; return; }
        adg = (last.Weight - first.Weight) / days;
        adgDays = (int)days;
    }

    private async Task SaveWeight()
    {
        newWeight.GoatId = Id;
        newWeight.Date = newWeightDate ?? DateTime.UtcNow;
        await HealthSvc.CreateWeightAsync(newWeight);
        Snackbar.Add($"Logged {newWeight.Weight:F1} lbs", Severity.Success);
        newWeight = new();
        newWeightDate = DateTime.Today;
        showWeightForm = false;
        weights = await HealthSvc.GetWeightsAsync(Id);
        RebuildWeightChart();
        ComputeAdg();
    }

    private async Task DeleteWeight(int id)
    {
        await HealthSvc.DeleteWeightAsync(id);
        weights = await HealthSvc.GetWeightsAsync(Id);
        RebuildWeightChart();
        ComputeAdg();
    }

    private async Task UploadPhoto(IBrowserFile? file)
    {
        if (file == null || goat == null) return;
        uploadingPhoto = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var isPrimary = goat.Photos?.Count == 0;
            var saved = await GoatSvc.UploadPhotoAsync(Id, stream, file.Name, caption: null, isPrimary: isPrimary);
            if (saved != null)
            {
                Snackbar.Add("Photo uploaded", Severity.Success);
                goat = await GoatSvc.GetAsync(Id);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            uploadingPhoto = false;
        }
    }

    private async Task DeletePhoto(int photoId)
    {
        var confirmed = await Dialog.ShowMessageBox("Delete photo", "Remove this photo?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        await GoatSvc.DeletePhotoAsync(Id, photoId);
        goat = await GoatSvc.GetAsync(Id);
        Snackbar.Add("Photo removed", Severity.Info);
    }

    private async Task DeleteGoat()
    {
        var result = await Dialog.ShowMessageBox("Delete Goat",
            $"Are you sure you want to delete {goat?.Name}? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (result == true)
        {
            await GoatSvc.DeleteAsync(Id);
            Snackbar.Add($"{goat?.Name} removed", Severity.Info);
            Nav.NavigateTo("/herd");
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0].ToUpper();
    }

    private string GetAvatarClass(Gender g) => g switch
    {
        Gender.Female => "goat-avatar-female",
        Gender.Male => "goat-avatar-male",
        _ => "goat-avatar-wether"
    };

    private string AgeString(DateTime dob)
    {
        var age = DateTime.Now - dob;
        var years = (int)(age.TotalDays / 365.25);
        var months = (int)((age.TotalDays % 365.25) / 30.44);
        if (years == 0 && months == 0) return "less than a month";
        if (years == 0) return $"{months}mo";
        return $"{years}y {months}mo";
    }

    private string GetFamachaIconBg(int score) => score switch
    {
        1 => "record-card-icon-green",
        2 => "record-card-icon-teal",
        3 => "record-card-icon-orange",
        4 => "record-card-icon-red",
        5 => "record-card-icon-red",
        _ => "record-card-icon-neutral"
    };

    private Color GetPaymentColor(PaymentStatus s) => s switch
    {
        PaymentStatus.PaidInFull => Color.Success,
        PaymentStatus.Deposited  => Color.Info,
        PaymentStatus.Pending    => Color.Warning,
        PaymentStatus.Refunded   => Color.Error,
        _                        => Color.Default
    };

    private string GetSaleTypeIcon(SaleType t) => t switch
    {
        SaleType.LiveAnimal => GoatLabIcons.Hoof,
        SaleType.Milk       => Icons.Material.Filled.LocalDrink,
        SaleType.Meat       => Icons.Material.Filled.Restaurant,
        SaleType.Breeding   => Icons.Material.Filled.Favorite,
        _                   => Icons.Material.Filled.ShoppingBag
    };

    private string GetSaleTypeIconBg(SaleType t) => t switch
    {
        SaleType.LiveAnimal => "record-card-icon-green",
        SaleType.Milk       => "record-card-icon-blue",
        SaleType.Meat       => "record-card-icon-red",
        SaleType.Breeding   => "record-card-icon-pink",
        _                   => "record-card-icon-teal"
    };

    // --- Shows + Appraisals ---

    private async Task AddShow()
    {
        var parameters = new DialogParameters { ["GoatId"] = Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dlg = await Dialog.ShowAsync<AddShowRecordDialog>("Add show record", parameters, options);
        var result = await dlg.Result;
        if (result != null && !result.Canceled) showRecordsList = await ShowSvc.GetShowsAsync(Id);
    }

    private async Task DeleteShow(int showId)
    {
        var confirm = await Dialog.ShowMessageBox("Delete show record?", "", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await ShowSvc.DeleteShowAsync(showId);
        showRecordsList = await ShowSvc.GetShowsAsync(Id);
        Snackbar.Add("Show record deleted", Severity.Info);
    }

    private async Task AddAppraisal()
    {
        var parameters = new DialogParameters { ["GoatId"] = Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dlg = await Dialog.ShowAsync<AddAppraisalDialog>("Add linear appraisal", parameters, options);
        var result = await dlg.Result;
        if (result != null && !result.Canceled) appraisals = await ShowSvc.GetAppraisalsAsync(Id);
    }

    private async Task DeleteAppraisal(int appraisalId)
    {
        var confirm = await Dialog.ShowMessageBox("Delete appraisal?", "", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await ShowSvc.DeleteAppraisalAsync(appraisalId);
        appraisals = await ShowSvc.GetAppraisalsAsync(Id);
    }

    private static Color PlacingColor(int p) => p switch
    {
        1 => Color.Warning,      // gold-ish
        2 => Color.Default,       // silver
        3 => Color.Tertiary,      // bronze
        _ => Color.Info
    };

    private static string PlacingLabel(int p) => p switch
    {
        1 => "1st",
        2 => "2nd",
        3 => "3rd",
        _ => $"{p}th"
    };

    private static string ClassColor(LinearAppraisalClassification? c) => c switch
    {
        LinearAppraisalClassification.Excellent => "#1b5e20",
        LinearAppraisalClassification.VeryGood => "#2e7d32",
        LinearAppraisalClassification.GoodPlus => "#558b2f",
        LinearAppraisalClassification.Good => "#f9a825",
        LinearAppraisalClassification.Fair => "#ef6c00",
        LinearAppraisalClassification.Poor => "#c62828",
        _ => "#757575"
    };

    private static string ClassLabel(LinearAppraisalClassification c) => c switch
    {
        LinearAppraisalClassification.Excellent => "Excellent (EX)",
        LinearAppraisalClassification.VeryGood => "Very Good (VG)",
        LinearAppraisalClassification.GoodPlus => "Good Plus (G+)",
        LinearAppraisalClassification.Good => "Good (G)",
        LinearAppraisalClassification.Fair => "Fair (F)",
        LinearAppraisalClassification.Poor => "Poor (P)",
        _ => c.ToString()
    };

    // --- Documents ---

    private async Task UploadDocument(IBrowserFile? file)
    {
        if (file == null || string.IsNullOrWhiteSpace(docTitle)) return;
        uploadingDoc = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            await GoatSvc.UploadDocumentAsync(Id, stream, file.Name, docTitle!.Trim(), docType);
            Snackbar.Add($"{docTitle} uploaded", Severity.Success);
            docTitle = null;
            docType = null;
            goat = await GoatSvc.GetAsync(Id);
        }
        catch (Exception ex) { Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error); }
        finally { uploadingDoc = false; }
    }

    private async Task DeleteDocument(int docId)
    {
        var confirm = await Dialog.ShowMessageBox("Delete document?", "This cannot be undone.", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await GoatSvc.DeleteDocumentAsync(Id, docId);
        goat = await GoatSvc.GetAsync(Id);
        Snackbar.Add("Document deleted", Severity.Info);
    }

    private static string DocumentIcon(string filePath)
    {
        var ext = System.IO.Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => Icons.Material.Filled.PictureAsPdf,
            ".jpg" or ".jpeg" or ".png" or ".webp" or ".heic" => Icons.Material.Filled.Image,
            ".doc" or ".docx" => Icons.Material.Filled.Description,
            _ => Icons.Material.Filled.InsertDriveFile
        };
    }

    // --- Lactations & test days ---

    private async Task StartLactation()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters { ["GoatId"] = Id };
        var dlg = await Dialog.ShowAsync<StartLactationDialog>("Start lactation", parameters, options);
        var result = await dlg.Result;
        if (result != null && !result.Canceled) lactations = await MilkSvc.GetLactationsAsync(Id);
    }

    private async Task DryOff(LactationSummary lac)
    {
        var confirm = await Dialog.ShowMessageBox("Dry off?",
            $"Record dry-off date of today for Lactation #{lac.LactationNumber}?",
            yesText: "Dry off", cancelText: "Cancel");
        if (confirm != true) return;

        await MilkSvc.UpdateLactationAsync(new Lactation
        {
            Id = lac.Id,
            GoatId = lac.GoatId,
            LactationNumber = lac.LactationNumber,
            FreshenDate = lac.FreshenDate,
            DryOffDate = DateTime.Today,
            KiddingRecordId = lac.KiddingRecordId,
            Notes = lac.Notes
        });
        Snackbar.Add($"Lactation #{lac.LactationNumber} dried off", Severity.Success);
        lactations = await MilkSvc.GetLactationsAsync(Id);
    }

    private async Task DeleteLactation(int id)
    {
        var confirm = await Dialog.ShowMessageBox("Delete lactation?",
            "This removes the lactation record and all its test days. Daily milk logs are not affected.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await MilkSvc.DeleteLactationAsync(id);
        lactations = await MilkSvc.GetLactationsAsync(Id);
    }

    private async Task AddTestDay(LactationSummary lac)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters { ["LactationId"] = lac.Id, ["GoatId"] = lac.GoatId };
        var dlg = await Dialog.ShowAsync<AddTestDayDialog>("Record test day", parameters, options);
        var result = await dlg.Result;
        if (result != null && !result.Canceled) lactations = await MilkSvc.GetLactationsAsync(Id);
    }

    private async Task DeleteTestDay(int id)
    {
        await MilkSvc.DeleteTestDayAsync(id);
        lactations = await MilkSvc.GetLactationsAsync(Id);
    }
}
