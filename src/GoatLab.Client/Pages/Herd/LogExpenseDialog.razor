@inject FinanceService FinanceSvc
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <div style="display:flex;flex-direction:column;gap:12px;">
            <MudDatePicker @bind-Date="date" Label="Date" Variant="Variant.Outlined" Editable />
            <MudTextField @bind-Value="description" Label="Description" Variant="Variant.Outlined" Required />
            <MudGrid>
                <MudItem xs="6">
                    <MudNumericField T="decimal" @bind-Value="amount" Label="Amount" Variant="Variant.Outlined"
                                     Adornment="Adornment.Start" AdornmentText="$" Min="0m" Step="0.01m" />
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="ExpenseCategory" @bind-Value="category" Label="Category" Variant="Variant.Outlined">
                        @foreach (var c in Enum.GetValues<ExpenseCategory>())
                        {
                            <MudSelectItem Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            <MudTextField @bind-Value="notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@(saving || string.IsNullOrWhiteSpace(description) || amount <= 0)">
            @(saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? GoatId { get; set; }

    private DateTime? date = DateTime.Today;
    private string? description;
    private decimal amount;
    private ExpenseCategory category = ExpenseCategory.Feed;
    private string? notes;
    private bool saving;

    private async Task Save()
    {
        saving = true;
        try
        {
            await FinanceSvc.CreateAsync(new Transaction
            {
                Type = TransactionType.Expense,
                Date = date ?? DateTime.Today,
                Description = description!.Trim(),
                Amount = amount,
                Category = category.ToString(),
                GoatId = GoatId,
                Notes = notes
            });
            Snackbar.Add("Expense logged", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
