                new WorkflowTask(14, "Day -16", "Reduce rich feed", "Avoid pregnancy toxemia — quality over quantity. No sudden changes."),
                new WorkflowTask(21, "Day -9", "Observation increases", "Watch for ligaments loosening (pin bones), udder filling."),
                new WorkflowTask(25, "Day -5", "Trim rear + udder", "Hair clipping around udder and vulva for hygiene."),
                new WorkflowTask(28, "Day -2", "Night-watch schedule", "Set up monitoring. First-timers need closer watch."),
                new WorkflowTask(30, "Day 0 (est.)", "Expected kidding date", "Mark on calendar. Keep kidding kit within reach 24/7.")
            }
        },
        new WorkflowDef
        {
            Title = "Sick Goat Triage",
            Description = "First 48 hours when a goat goes off-feed.",
