                new WorkflowTask(42, "Week 6", "Move to pasture C", "Keep cycling. Don't return to A yet."),
                new WorkflowTask(63, "Week 9", "Fecal egg count", "Confirm your rotation is working. Adjust if resistant."),
                new WorkflowTask(84, "Week 12", "Pasture A safe to reuse", "~84 days since last grazing = clean.")
