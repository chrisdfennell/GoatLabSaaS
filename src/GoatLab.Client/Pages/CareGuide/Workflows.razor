                new WorkflowTask(0, "Today", "Dip navel in 7% iodine", "Dip within the first hour. Repeat at 12 hrs."),
                new WorkflowTask(0, "Today", "Colostrum within 1 hour", "Make sure kid nurses or bottle-feed 10% body weight in colostrum."),
                new WorkflowTask(1, "Day 1", "Weight + tag", "Record birth weight. Apply ear tag or tattoo."),
                new WorkflowTask(1, "Day 1", "BoSe / selenium injection", "If your area is Se-deficient. Check with vet."),
                new WorkflowTask(4, "Day 4", "Disbud", "Between days 4–10. Sooner for fast-growing bucks."),
                new WorkflowTask(14, "Week 2", "Introduce hay", "Offer soft fine-leaf hay to encourage rumen development."),
                new WorkflowTask(21, "Week 3", "Coccidia prevention", "Start in wet conditions or if group housed."),
                new WorkflowTask(42, "Week 6", "CDT first dose", "6–8 weeks of age. Record in GoatLab."),
                new WorkflowTask(63, "Week 9", "CDT booster", "3 weeks after first dose."),
                new WorkflowTask(56, "Week 8", "Weaning prep", "Start reducing nursing time. Introduce grower ration."),
                new WorkflowTask(84, "Week 12", "Banding (if wether)", "Between 8–16 weeks depending on breed. Vaccinate CDT before banding.")
            }
        },
        new WorkflowDef
        {
            Title = "New Goat Arrived",
