            Icon = Icons.Material.Filled.ExitToApp,
            Color = "#1565c0",
            NeedsGoat = true,
            Tasks = new()
            {
                new WorkflowTask(0, "Arrival", "Quarantine 30 days", "Separate housing, feed, water — no contact with herd."),
                new WorkflowTask(0, "Arrival", "Intake exam", "Check temp, FAMACHA, BCS, hoof condition. Take photos."),
                new WorkflowTask(1, "Day 1", "Fecal egg count", "Before deworming. Rule out parasite load / resistance."),
                new WorkflowTask(2, "Day 2", "Deworm", "With appropriate class based on FEC. Isolate manure."),
