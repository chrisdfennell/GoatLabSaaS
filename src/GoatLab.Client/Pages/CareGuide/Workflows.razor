            Tasks = new()
            {
                new WorkflowTask(0, "Week 0", "Buck evaluation", "Hooves, weight, fertility test. Trim beard."),
                new WorkflowTask(0, "Week 0", "Doe evaluation", "BCS check — aim for 3. Deworm if FAMACHA ≥ 3."),
                new WorkflowTask(14, "Week 2", "Flushing begins", "Increase doe nutrition for 2 weeks — grain or better pasture."),
                new WorkflowTask(14, "Week 2", "Pre-breed vaccinations", "CDT for does 30 days before intro (passes to kids)."),
                new WorkflowTask(28, "Week 4", "Buck intro", "Turn bucks into breeding groups. Crayon or paint on brisket."),
                new WorkflowTask(28, "Week 4", "Log first heat", "Start recording in GoatLab Breeding."),
                new WorkflowTask(49, "Week 7", "21-day return check", "Watch for repeats — does that come back in heat haven't conceived."),
                new WorkflowTask(70, "Week 10", "Pregnancy test", "Ultrasound or blood test for confirmed pregnancies.")
            }
        }
    };
}
