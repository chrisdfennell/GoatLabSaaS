@page "/care-guide/workflows"
@inject CalendarService CalSvc
@inject GoatService GoatSvc
@inject ISnackbar Snackbar

<PageTitle>Workflows — GoatLab</PageTitle>

<div class="page-hero page-hero-green">
    <div class="page-hero-icon">
        <MudIcon Icon="@Icons.Material.Filled.Checklist" />
    </div>
    <div class="page-hero-text">
        <MudText Typo="Typo.overline" Class="page-hero-eyebrow">Workflows</MudText>
        <MudText Typo="Typo.h4" Class="page-hero-title">Checklist Generators</MudText>
        <MudText Typo="Typo.body2" Class="page-hero-sub">Pick a situation, we schedule the must-do tasks into your Calendar.</MudText>
    </div>
    <div style="position:relative;z-index:1;">
        <MudButton Variant="Variant.Filled" Style="background:rgba(255,255,255,0.92);color:#1b5e20;"
                   StartIcon="@Icons.Material.Filled.ArrowBack" Href="/care-guide">Back</MudButton>
    </div>
</div>

<MudGrid>
    @foreach (var wf in workflows)
    {
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 workflow-card" Outlined Elevation="0" Style="@($"border-top:4px solid {wf.Color};")">
                <div class="d-flex align-center mb-2" style="gap:12px;">
                    <div class="record-card-icon" style="@($"background:{wf.Color};width:48px;height:48px;")">
                        <MudIcon Icon="@wf.Icon" />
                    </div>
                    <div style="flex:1;">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700;">@wf.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@wf.Description</MudText>
                    </div>
                </div>

                <MudText Typo="Typo.caption" Style="text-transform:uppercase;letter-spacing:1px;color:#888;" Class="mt-2 d-block">Schedule</MudText>
                <ul class="workflow-list">
                    @foreach (var t in wf.Tasks)
                    {
                        <li><strong>@t.Offset:</strong> @t.Title</li>
                    }
                </ul>

                <div class="d-flex gap-2 mt-3">
                    <MudDatePicker @bind-Date="wf.StartDate" Variant="Variant.Outlined"
                                   PickerVariant="PickerVariant.Inline" Editable Style="max-width:180px;" />
                    @if (wf.NeedsGoat)
                    {
                        <MudSelect T="int?" @bind-Value="wf.GoatId" Label="Goat" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                            @if (goats != null)
                            {
                                @foreach (var g in goats)
                                {
                                    <MudSelectItem Value="@((int?)g.Id)">@g.Name</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    }
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="() => GenerateChecklist(wf)">
                        Schedule
                    </MudButton>
                </div>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<style>
.workflow-card { border-radius: 12px !important; }
.workflow-list { padding-left: 18px; margin: 4px 0; line-height: 1.6; }
.workflow-list li { font-size: 0.9rem; }
</style>

@code {
    private List<Goat>? goats;

    protected override async Task OnInitializedAsync()
    {
        goats = await GoatSvc.GetAllAsync();
    }

    private async Task GenerateChecklist(WorkflowDef wf)
    {
        if (!wf.StartDate.HasValue) { Snackbar.Add("Pick a start date", Severity.Warning); return; }
        if (wf.NeedsGoat && wf.GoatId == null) { Snackbar.Add("Pick a goat", Severity.Warning); return; }

        var start = wf.StartDate.Value;
        var goatName = wf.NeedsGoat ? goats?.FirstOrDefault(g => g.Id == wf.GoatId)?.Name : null;
        var added = 0;
        foreach (var t in wf.Tasks)
        {
            var when = start.AddDays(t.Days);
            await CalSvc.CreateEventAsync(new CalendarEvent
            {
                Title = goatName != null ? $"{goatName} — {t.Title}" : $"{wf.Title}: {t.Title}",
                Description = t.Detail,
                Start = when,
                AllDay = true,
                GoatId = wf.GoatId
            });
            added++;
        }
        Snackbar.Add($"Scheduled {added} events starting {start:MMM d, yyyy}", Severity.Success);
    }

    private class WorkflowDef
    {
        public string Title { get; init; } = "";
        public string Description { get; init; } = "";
        public string Icon { get; init; } = "";
        public string Color { get; init; } = "";
        public bool NeedsGoat { get; init; }
        public List<WorkflowTask> Tasks { get; init; } = new();
        public DateTime? StartDate { get; set; } = DateTime.Today;
        public int? GoatId { get; set; }
    }

    private record WorkflowTask(int Days, string Offset, string Title, string Detail);

    private readonly List<WorkflowDef> workflows = new()
    {
        new WorkflowDef
