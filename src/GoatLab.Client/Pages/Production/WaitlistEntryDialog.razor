@* Add / edit a WaitlistEntry. Parent passes a fresh copy so Cancel doesn't dirty the original. *@
@inject SalesService SalesSvc
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <div class="d-flex align-center" style="gap:4px;">
                    <MudSelect T="int" @bind-Value="Entry.CustomerId" Label="Customer" Variant="Variant.Outlined" Required Class="flex-grow-1">
                        @foreach (var c in Customers)
                        {
                            <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Text="Add a new customer">
                        <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary"
                                       OnClick="() => _showNewCustomer = !_showNewCustomer" />
                    </MudTooltip>
                </div>
            </MudItem>
            @if (_showNewCustomer)
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-3" Outlined Style="border-radius:10px;">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">New customer</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="_newCustomer.Name" Label="Name" Variant="Variant.Outlined" Required />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="_newCustomer.Email" Label="Email" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="_newCustomer.Phone" Label="Phone" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                        <div class="d-flex gap-2 mt-2 justify-end">
                            <MudButton Variant="Variant.Text" OnClick="() => { _showNewCustomer = false; _newCustomer = new(); }">Cancel</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="AddCustomerAsync" Disabled="_savingCustomer">Add</MudButton>
                        </div>
                    </MudPaper>
                </MudItem>
            }
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="Entry.Priority" Label="Priority (higher = earlier)" Variant="Variant.Outlined" Min="0" Max="999" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Entry.BreedPreference" Label="Breed preference" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="Gender?" @bind-Value="Entry.SexPreference" Label="Sex" Variant="Variant.Outlined" Clearable>
                    <MudSelectItem T="Gender?" Value="null">Either</MudSelectItem>
                    <MudSelectItem T="Gender?" Value="Gender.Female">Doe</MudSelectItem>
                    <MudSelectItem T="Gender?" Value="Gender.Male">Buck</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="Entry.ColorPreference" Label="Color" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_minDue" Label="Earliest due date" Variant="Variant.Outlined" Editable />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_maxDue" Label="Latest due date" Variant="Variant.Outlined" Editable />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField T="decimal" Value="@DepositDollars" ValueChanged="@(v => DepositDollars = v)" Label="Deposit ($)" Variant="Variant.Outlined" Format="F2" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="Entry.DepositPaid" Color="Color.Success" Label="Deposit received" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Entry.Notes" Label="Notes" Variant="Variant.Outlined" Lines="3" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(Entry.CustomerId == 0)">@SaveLabel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public WaitlistEntry Entry { get; set; } = new();
    [Parameter] public List<Customer> Customers { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private DateTime? _minDue;
    private DateTime? _maxDue;

    private bool _showNewCustomer;
    private bool _savingCustomer;
    private Customer _newCustomer = new();

    protected override void OnInitialized()
    {
        _minDue = Entry.MinDueDate;
        _maxDue = Entry.MaxDueDate;
    }

    private async Task AddCustomerAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCustomer.Name))
        {
            Snackbar.Add("Name is required.", Severity.Warning);
            return;
        }
        _savingCustomer = true;
        try
        {
            var created = await SalesSvc.CreateCustomerAsync(_newCustomer);
            if (created is null) return;
            Customers.Add(created);
            Entry.CustomerId = created.Id;
            Snackbar.Add($"Added {created.Name}", Severity.Success);
            _newCustomer = new();
            _showNewCustomer = false;
        }
        finally { _savingCustomer = false; }
    }

    private decimal DepositDollars
    {
        get => Entry.DepositCents / 100m;
        set => Entry.DepositCents = (int)Math.Round(value * 100);
    }

    private string SaveLabel => IsEdit ? "Save" : "Add to waitlist";

    private void Save()
    {
        Entry.MinDueDate = _minDue;
        Entry.MaxDueDate = _maxDue;
        MudDialog.Close(DialogResult.Ok(Entry));
    }

    private void Cancel() => MudDialog.Cancel();
}
