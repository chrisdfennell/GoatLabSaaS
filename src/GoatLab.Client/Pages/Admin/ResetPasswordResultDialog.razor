@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-2" />
            <MudText Typo="Typo.h6">Temporary password</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-3" Dense>
            Copy this now — it isn't stored and won't be shown again.
        </MudAlert>
        <MudText Typo="Typo.caption" Color="Color.Secondary">User</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">@Email</MudText>

        <MudText Typo="Typo.caption" Color="Color.Secondary">New password</MudText>
        <div class="d-flex align-center" style="gap:8px;">
            <MudTextField Value="@Password" ReadOnly Variant="Variant.Outlined"
                          Style="font-family:ui-monospace,monospace;font-size:1.05rem;" T="string" />
            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="CopyAsync" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Done</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Email { get; set; } = string.Empty;
    [Parameter] public string Password { get; set; } = string.Empty;

    private async Task CopyAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Password);
            Snackbar.Add("Copied.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Clipboard access blocked — copy manually.", Severity.Warning);
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
