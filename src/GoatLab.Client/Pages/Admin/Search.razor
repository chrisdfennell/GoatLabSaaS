@page "/admin/search"
@inject AdminOpsService Ops
@inject NavigationManager Nav

<PageTitle>Cross-tenant search — Admin — GoatLab</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudText Typo="Typo.h4" Class="mb-2">Cross-tenant search</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Find a tenant, user, goat, customer, or sale across every farm. Use this for support triage when
        a customer mentions a name, ear tag, registration number, email, or sale id.
    </MudText>

    <div class="d-flex" style="gap:8px;">
        <MudTextField @bind-Value="_query" Label="Search…" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      OnKeyUp="@(e => { if (e.Key == "Enter") _ = Run(); })"
                      Style="flex:1;" />
        <MudButton OnClick="Run" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="_busy">Search</MudButton>
    </div>

    @if (_results is not null)
    {
        @if (_results.Hits.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">No matches for "@_results.Query".</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3 mb-2 d-block">
                @_results.Hits.Count result(s)
                @if (_results.Truncated)
                {
                    <span> · some categories truncated — narrow the query for more</span>
                }
            </MudText>
            @foreach (var typeGroup in _results.Hits.GroupBy(h => h.Type))
            {
                <MudPaper Class="pa-3 mb-3" Outlined Elevation="0">
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="text-transform:uppercase;letter-spacing:1px;color:#2e7d32;">
                        @typeGroup.Key (@typeGroup.Count())
                    </MudText>
                    @foreach (var hit in typeGroup)
                    {
                        <div class="search-row" @onclick="@(() => Nav.NavigateTo(hit.DeepLink))">
                            <div class="search-row-title">@hit.Title</div>
                            <div class="search-row-sub">@hit.Subtitle</div>
                        </div>
                    }
                </MudPaper>
            }
        }
    }
</MudContainer>

<style>
    .search-row { padding: 8px 10px; border-radius: 6px; cursor: pointer; }
    .search-row:hover { background: rgba(46,125,50,0.08); }
    .search-row-title { font-weight: 600; }
    .search-row-sub { font-size: 0.85rem; color: #6b7a70; }
</style>

@code {
    private string _query = "";
    private AdminSearchResponse? _results;
    private bool _busy;

    private async Task Run()
    {
        if (string.IsNullOrWhiteSpace(_query) || _query.Trim().Length < 2) return;
        _busy = true;
        try { _results = await Ops.SearchAsync(_query, 25); }
        finally { _busy = false; }
    }
}
