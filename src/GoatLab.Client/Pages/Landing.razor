@page "/"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout GoatLab.Client.Layout.LandingLayout
@inject NavigationManager Nav
@inject BillingService BillingApi

<PageTitle>GoatLab — Herd management for modern goat farmers</PageTitle>

<HeadContent>
    <meta name="description" content="GoatLab is the all-in-one herd management platform for goat farmers. Track health, breeding, milk production, finances, and the whole farm — on any device, even offline." />
</HeadContent>

@* ---------- TOP NAV ---------- *@
<header class="site-nav">
    <div class="nav-inner">
        <a href="/" class="brand" aria-label="GoatLab home">
            <MudIcon Icon="@GoatLabIcons.Hoof" Style="font-size:28px;color:#2e7d32;" />
            <span>GoatLab</span>
        </a>
        <nav class="nav-links">
            <a href="#features">Features</a>
            <a href="#workflow">How it works</a>
            <a href="#pricing">Pricing</a>
            <a href="#self-host">Self-host</a>
            <a href="#faq">FAQ</a>
            <a href="/login">Sign in</a>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/register" Class="nav-cta"
                       EndIcon="@Icons.Material.Filled.ArrowForward">Start free</MudButton>
        </nav>
    </div>
</header>

@* ---------- HERO ---------- *@
<section class="hero">
    <div class="hero-inner">
        <div class="hero-copy">
            <div class="eyebrow">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Style="font-size:16px;" />
                <span>Built for real goat farms — not generic livestock software</span>
            </div>
            <h1>Run your whole goat operation from one dashboard.</h1>
            <p class="lede">
                GoatLab tracks every goat, kidding, vet visit, milking, feed bag, and dollar — so you can
                stop juggling spreadsheets and start making better decisions. Works on phones, tablets,
                and laptops. Works offline in the barn.
            </p>
            <div class="hero-ctas">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Href="/register" EndIcon="@Icons.Material.Filled.ArrowForward">
                    Start free — no credit card
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                           Href="#features" StartIcon="@Icons.Material.Filled.PlayCircleOutline">
                    See what's inside
                </MudButton>
            </div>
            <div class="hero-trust">
                <div class="trust-item">
                    <MudIcon Icon="@Icons.Material.Filled.OfflineBolt" Style="color:#2e7d32;" />
                    <span>Works offline</span>
                </div>
                <div class="trust-item">
                    <MudIcon Icon="@Icons.Material.Filled.PhoneIphone" Style="color:#2e7d32;" />
                    <span>Install on any device</span>
                </div>
                <div class="trust-item">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Style="color:#2e7d32;" />
                    <span>Your data, your farm</span>
                </div>
            </div>
        </div>

        <div class="hero-preview" aria-hidden="true">
            <div class="preview-frame">
                <div class="preview-topbar">
                    <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
                    <span class="preview-url">goatlab.app / dashboard</span>
                </div>
                <div class="preview-body">
                    <div class="pv-welcome">
                        <div>
                            <div class="pv-greet">Good morning!</div>
                            <div class="pv-sub">You have <b>47 goats</b> in your herd.</div>
                        </div>
                        <div class="pv-weather">
                            <MudIcon Icon="@Icons.Material.Filled.WbSunny" Style="color:#fff;font-size:40px;" />
                            <div>
                                <div class="pv-temp">72°F</div>
                                <div class="pv-cond">Clear · feels 70°</div>
                            </div>
                        </div>
                    </div>
                    <div class="pv-stats">
                        <div class="pv-stat pv-green"><b>47</b><span>Total</span></div>
                        <div class="pv-stat pv-teal"><b>32</b><span>Does</span></div>
                        <div class="pv-stat pv-blue"><b>11</b><span>Bucks</span></div>
                        <div class="pv-stat pv-pink"><b>6</b><span>Pregnant</span></div>
                        <div class="pv-stat pv-orange"><b>1</b><span>Sick</span></div>
                    </div>
                    <div class="pv-row">
                        <div class="pv-card">
                            <div class="pv-card-title">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="color:#2e7d32;font-size:18px;" />
                                Milk · 30 days
                            </div>
                            <svg viewBox="0 0 200 60" class="pv-chart" preserveAspectRatio="none">
                                <polyline points="0,48 20,42 40,44 60,36 80,30 100,34 120,24 140,22 160,18 180,14 200,10"
                                          fill="none" stroke="#2e7d32" stroke-width="2.5" />
                                <polyline points="0,48 20,42 40,44 60,36 80,30 100,34 120,24 140,22 160,18 180,14 200,10 200,60 0,60"
                                          fill="rgba(46,125,50,0.12)" stroke="none" />
                            </svg>
                        </div>
                        <div class="pv-card">
                            <div class="pv-card-title">
                                <MudIcon Icon="@Icons.Material.Filled.History" Style="color:#2e7d32;font-size:18px;" />
                                Recent activity
                            </div>
                            <div class="pv-activity">
                                <div><span class="pv-dot pv-dot-blue"></span>Logged 3.2 lbs from Pearl · 2m ago</div>
                                <div><span class="pv-dot pv-dot-warn"></span>CDT booster for Clover · 1h ago</div>
                                <div><span class="pv-dot pv-dot-green"></span>Daisy added to herd · 3d ago</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ---------- FEATURES ---------- *@
<section class="features" id="features">
    <div class="container">
        <div class="section-head">
            <div class="eyebrow dark">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Style="font-size:16px;" />
                <span>Everything in one place</span>
            </div>
            <h2>Run the farm. Skip the spreadsheets.</h2>
            <p>GoatLab replaces the notebook on the barn wall, the breeding chart in the kitchen, and
               the sales receipts in the glovebox — with one app that works online or off.</p>
        </div>

        <div class="feature-grid">
            @foreach (var f in _features)
            {
                <div class="feature-card">
                    <div class="feature-icon" style="background:@f.Bg;color:@f.Fg;">
                        <MudIcon Icon="@f.Icon" Style="font-size:28px;" />
                    </div>
                    <h3>@f.Title</h3>
                    <p>@f.Body</p>
                </div>
            }
        </div>
    </div>
</section>

@* ---------- WORKFLOW ---------- *@
<section class="workflow" id="workflow">
    <div class="container">
        <div class="section-head">
            <div class="eyebrow">
                <MudIcon Icon="@Icons.Material.Filled.Route" Style="font-size:16px;" />
                <span>How it works</span>
            </div>
            <h2>Set up in minutes. Useful on day one.</h2>
        </div>

        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <h3>Create your farm</h3>
                <p>Sign up and name your operation. Invite helpers later with their own roles.</p>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <h3>Add your herd</h3>
                <p>Enter goats one by one, or import a CSV. Tags, birthdays, lineage — all optional.</p>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <h3>Log what happens</h3>
                <p>Milkings, vet visits, breedings, sales. From your phone in the barn, even offline.</p>
            </div>
            <div class="step">
                <div class="step-num">4</div>
                <h3>See the whole picture</h3>
                <p>Real dashboards with trends, alerts, and financials — so you can act, not guess.</p>
            </div>
        </div>
    </div>
</section>

@* ---------- PRICING ---------- *@
<section class="pricing" id="pricing">
    <div class="container">
        <div class="section-head">
            <div class="eyebrow dark">
                <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Style="font-size:16px;" />
                <span>Simple, honest pricing</span>
            </div>
            <h2>Start free. Grow when you're ready.</h2>
        </div>

        <div class="plan-grid">
            @if (_plans is null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else
            {
                @for (var i = 0; i < _plans.Count; i++)
                {
                    var plan = _plans[i];
                    var featured = IsFeaturedPlan(i, _plans.Count);
                    <div class="plan @(featured ? "featured" : "")">
                        @if (featured) { <div class="plan-badge">Most popular</div> }
                        <div class="plan-name">@plan.Name</div>
                        <div class="plan-price">
                            @(plan.PriceMonthlyCents == 0 ? "Free" : $"${plan.PriceMonthlyCents / 100m:0}")
                            <span>@(plan.PriceMonthlyCents == 0 ? "forever" : "/ month")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(plan.Description))
                        {
                            <div class="plan-line">@plan.Description</div>
                        }
                        <ul>
                            <li>
                                <MudIcon Icon="@Icons.Material.Filled.Check" />
                                @(plan.MaxGoats?.ToString() ?? "Unlimited") goats
                            </li>
                            <li>
                                <MudIcon Icon="@Icons.Material.Filled.Check" />
                                @(plan.MaxUsers?.ToString() ?? "Unlimited") users
                            </li>
                            @foreach (var f in plan.Features.Where(f => f.Enabled))
                            {
                                <li><MudIcon Icon="@Icons.Material.Filled.Check" /> @FeatureLabel(f.Feature)</li>
                            }
                        </ul>
                        <MudButton Variant="@(featured ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Primary" FullWidth Href="/register">
                            @CtaLabel(plan)
                        </MudButton>
                    </div>
                }
            }
        </div>
    </div>
</section>

@* ---------- SELF-HOST / DOCKER ---------- *@
<section class="self-host" id="self-host">
    <div class="container self-host-inner">
        <div class="self-host-copy">
            <div class="eyebrow">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Style="font-size:16px;" />
                <span>Own your data</span>
            </div>
            <h2>Run GoatLab on your own hardware.</h2>
            <p>
                Prefer to keep your farm data off the cloud? GoatLab ships as a single Docker container.
                Deploy it on a Raspberry Pi in the barn, a NAS in the office, or a VPS — whatever you
                already have. One <code>docker compose up</code> and the whole app is running locally,
                with its own SQL Server database and media volume.
            </p>
            <ul class="self-host-list">
                <li><MudIcon Icon="@Icons.Material.Filled.Check" /> Same app you see here — no feature lock-out</li>
                <li><MudIcon Icon="@Icons.Material.Filled.Check" /> Data stays on your network, in your volumes</li>
                <li><MudIcon Icon="@Icons.Material.Filled.Check" /> Runs on Linux, QNAP, Synology, and Windows</li>
                <li><MudIcon Icon="@Icons.Material.Filled.Check" /> Free and open — source on GitHub</li>
            </ul>
            <div class="self-host-ctas">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Href="@RepoUrl" Target="_blank"
                           StartIcon="@Icons.Custom.Brands.GitHub">
                    View on GitHub
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                           Href="@($"{RepoUrl}#self-hosting-with-docker")" Target="_blank"
                           EndIcon="@Icons.Material.Filled.ArrowForward">
                    Read the docs
                </MudButton>
            </div>
        </div>

        <div class="self-host-terminal" aria-hidden="true">
            <div class="term-topbar">
                <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
                <span class="term-title">~/goatlab</span>
            </div>
            <pre class="term-body"><span class="t-muted"># clone and launch</span>
<span class="t-prompt">$</span> git clone https://github.com/chrisdfennell/GoatLab.git
<span class="t-prompt">$</span> cd GoatLab
<span class="t-prompt">$</span> cp .env.example .env
<span class="t-prompt">$</span> docker compose up -d
<span class="t-muted">
[+] Running 3/3
 ✔ Network  goatlab_default       Created
 ✔ Container goatlab-sqlserver    Healthy
 ✔ Container goatlab              Started</span>

<span class="t-prompt">$</span> open http://localhost:8090
<span class="t-ok">  GoatLab is up. Start logging goats.</span>
</pre>
        </div>
    </div>
</section>

@* ---------- FAQ ---------- *@
<section class="faq" id="faq">
    <div class="container">
        <div class="section-head">
            <div class="eyebrow dark">
                <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Style="font-size:16px;" />
                <span>Frequently asked</span>
            </div>
            <h2>Answers before you sign up.</h2>
        </div>

        <div class="faq-grid">
            <details class="faq-item">
                <summary>Is there really a free plan, forever?</summary>
                <p>Yes. The Homestead plan is free for up to 10 goats and never expires. No credit card required to start.</p>
            </details>
            <details class="faq-item">
                <summary>Does GoatLab work offline in the barn?</summary>
                <p>Yes. Install GoatLab as a PWA on your phone or tablet and it keeps working with no signal. Your logs sync automatically the next time you're online.</p>
            </details>
            <details class="faq-item">
                <summary>Can I self-host GoatLab on my own server?</summary>
                <p>
                    Absolutely — GoatLab is open source and ships as a Docker image. Grab the repo from
                    <MudLink Href="@RepoUrl" Target="_blank" Underline="Underline.Always">@RepoUrl</MudLink>
                    and follow the self-hosting guide. Everything in the hosted version is in the container.
                </p>
            </details>
            <details class="faq-item">
                <summary>Where is my data stored?</summary>
                <p>On the hosted service, your data lives in an encrypted database in our cloud. If you self-host, it lives wherever your Docker volumes live — your NAS, your Pi, your server. You can export to CSV any time.</p>
            </details>
            <details class="faq-item">
                <summary>What devices does it run on?</summary>
                <p>Any modern browser — iPhone, Android, iPad, Windows, Mac, Linux. The dashboard is responsive and touch-friendly, with an installable PWA for offline use.</p>
            </details>
            <details class="faq-item">
                <summary>Can I import my existing spreadsheet?</summary>
                <p>Yes. Import your herd from CSV on day one. Milk records, kidding history, and sales can also be bulk-imported.</p>
            </details>
            <details class="faq-item">
                <summary>What if I want to cancel or switch to self-hosting later?</summary>
                <p>No lock-in. Export your full farm to CSV, spin up the Docker container, and import. You own your data.</p>
            </details>
            <details class="faq-item">
                <summary>Who's behind GoatLab?</summary>
                <p>Goat people who got tired of managing herds in a notebook. We build in the open on GitHub — issues, roadmap, and contributions welcome at <MudLink Href="@RepoUrl" Target="_blank" Underline="Underline.Always">@RepoUrl</MudLink>.</p>
            </details>
        </div>
    </div>
</section>

@* ---------- CTA ---------- *@
<section class="cta-band">
    <div class="container cta-inner">
        <h2>Your herd deserves better than a notebook.</h2>
        <p>Create a free account in under a minute. No credit card. No software to install.</p>
        <div class="cta-buttons">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/register"
                       EndIcon="@Icons.Material.Filled.ArrowForward">Get started</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large" Href="/login">
                I already have an account
            </MudButton>
        </div>
    </div>
</section>

@* ---------- FOOTER ---------- *@
<footer class="site-footer">
    <div class="container footer-inner">
        <div class="footer-brand">
            <MudIcon Icon="@GoatLabIcons.Hoof" Style="font-size:24px;color:#2e7d32;" />
            <span>GoatLab</span>
        </div>
        <div class="footer-links">
            <a href="#features">Features</a>
            <a href="#pricing">Pricing</a>
            <a href="#self-host">Self-host</a>
            <a href="#faq">FAQ</a>
            <a href="@RepoUrl" target="_blank" rel="noopener">GitHub</a>
            <a href="/terms">Terms</a>
            <a href="/privacy">Privacy</a>
            <a href="/login">Sign in</a>
            <a href="/register">Start free</a>
        </div>
        <div class="footer-copy">© @DateTime.Now.Year GoatLab. Made for goat people.</div>
    </div>
</footer>

<style>
    .landing-root { background:#fff; color:#1a2e1f; }
    .landing-root h1, .landing-root h2, .landing-root h3 { color:#102a1a; }
    .container { max-width:1180px; margin:0 auto; padding:0 28px; }

    /* Nav */
    .site-nav {
        position:sticky; top:0; z-index:20;
        background:rgba(255,255,255,0.92);
        backdrop-filter:blur(10px);
        border-bottom:1px solid rgba(0,0,0,0.06);
    }
    .nav-inner {
        max-width:1180px; margin:0 auto; padding:14px 28px;
        display:flex; align-items:center; justify-content:space-between;
    }
    .brand {
        display:flex; align-items:center; gap:8px;
        font-weight:800; font-size:20px; letter-spacing:-0.5px;
        color:#102a1a; text-decoration:none;
    }
    .nav-links { display:flex; align-items:center; gap:22px; }
    .nav-links a {
        color:#3a4a3e; text-decoration:none; font-weight:500; font-size:15px;
    }
    .nav-links a:hover { color:#2e7d32; }
    .nav-cta { border-radius:10px !important; }
    @@media (max-width: 720px) {
        .nav-links a:not(.nav-cta) { display:none; }
    }

    /* Hero */
    .hero {
        background:
            radial-gradient(1200px 500px at 90% -10%, rgba(102,187,106,0.25), transparent 60%),
            radial-gradient(900px 400px at -10% 10%, rgba(46,125,50,0.18), transparent 60%),
            linear-gradient(180deg, #f6fbf4 0%, #ffffff 100%);
        padding:80px 0 100px;
    }
    .hero-inner {
        max-width:1180px; margin:0 auto; padding:0 28px;
        display:grid; grid-template-columns: 1.05fr 1fr; gap:56px; align-items:center;
    }
    @@media (max-width: 960px) {
        .hero-inner { grid-template-columns: 1fr; gap:40px; }
        .hero { padding:56px 0 72px; }
    }
    .eyebrow {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(46,125,50,0.12); color:#1b5e20;
        padding:6px 12px; border-radius:999px;
        font-size:13px; font-weight:600; margin-bottom:18px;
    }
    .eyebrow.dark { background:rgba(46,125,50,0.1); }
    .hero-copy h1 {
        font-size:56px; line-height:1.05; font-weight:800;
        letter-spacing:-1.5px; margin:0 0 20px;
    }
    @@media (max-width: 720px) {
        .hero-copy h1 { font-size:40px; }
    }
    .hero-copy .lede {
        font-size:19px; line-height:1.55; color:#3a4a3e; margin:0 0 28px;
        max-width:540px;
    }
    .hero-ctas { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:28px; }
    .hero-trust {
        display:flex; gap:22px; flex-wrap:wrap; padding-top:16px;
        border-top:1px solid rgba(0,0,0,0.08);
    }
    .trust-item {
        display:flex; align-items:center; gap:8px;
        color:#3a4a3e; font-size:14px; font-weight:500;
    }

    /* Preview frame */
    .hero-preview { position:relative; }
    .preview-frame {
        background:#fff; border-radius:16px;
        box-shadow: 0 30px 60px -20px rgba(16,42,26,0.25), 0 8px 20px rgba(16,42,26,0.08);
        overflow:hidden; border:1px solid rgba(0,0,0,0.06);
    }
    .preview-topbar {
        display:flex; align-items:center; gap:6px;
        background:#f1f3f2; padding:10px 14px; border-bottom:1px solid rgba(0,0,0,0.06);
    }
    .preview-topbar .dot { width:10px; height:10px; border-radius:50%; }
    .preview-topbar .dot.r { background:#ff5f56; }
    .preview-topbar .dot.y { background:#ffbd2e; }
    .preview-topbar .dot.g { background:#27c93f; }
    .preview-url {
        margin-left:14px; font-size:12px; color:#6b7a70;
        font-family: ui-monospace, Menlo, monospace;
    }
    .preview-body { padding:16px; display:grid; gap:14px; }
    .pv-welcome {
        background:linear-gradient(135deg, #2e7d32, #558b2f);
        color:#fff; padding:16px; border-radius:12px;
        display:flex; align-items:center; justify-content:space-between; gap:16px;
    }
    .pv-greet { font-size:18px; font-weight:700; }
    .pv-sub { font-size:13px; opacity:0.9; margin-top:2px; }
    .pv-weather {
        display:flex; align-items:center; gap:10px;
        background:rgba(255,255,255,0.15); padding:8px 14px; border-radius:10px;
    }
    .pv-temp { font-size:22px; font-weight:700; line-height:1; }
    .pv-cond { font-size:11px; opacity:0.9; }
    .pv-stats {
        display:grid; grid-template-columns: repeat(5, 1fr); gap:10px;
    }
    .pv-stat {
        padding:12px 10px; border-radius:10px; color:#fff;
        display:flex; flex-direction:column; align-items:flex-start;
    }
    .pv-stat b { font-size:22px; font-weight:800; line-height:1; }
    .pv-stat span { font-size:11px; opacity:0.9; margin-top:4px; }
    .pv-green  { background: linear-gradient(135deg,#43a047,#2e7d32); }
    .pv-teal   { background: linear-gradient(135deg,#26a69a,#00897b); }
    .pv-blue   { background: linear-gradient(135deg,#42a5f5,#1976d2); }
    .pv-pink   { background: linear-gradient(135deg,#ec407a,#c2185b); }
    .pv-orange { background: linear-gradient(135deg,#ffa726,#ef6c00); }
    .pv-row { display:grid; grid-template-columns: 1.2fr 1fr; gap:12px; }
    .pv-card {
        border:1px solid rgba(0,0,0,0.08); border-radius:12px; padding:12px;
        background:#fafbf9;
    }
    .pv-card-title {
        display:flex; align-items:center; gap:6px;
        font-size:13px; font-weight:600; color:#1a2e1f; margin-bottom:8px;
    }
    .pv-chart { width:100%; height:70px; display:block; }
    .pv-activity { display:flex; flex-direction:column; gap:6px; font-size:12px; color:#3a4a3e; }
    .pv-activity > div { display:flex; align-items:center; gap:8px; }
    .pv-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .pv-dot-blue  { background:#42a5f5; }
    .pv-dot-warn  { background:#ffa726; }
    .pv-dot-green { background:#43a047; }

    /* Features */
    .features { padding:100px 0; background:#fff; }
    .section-head { max-width:720px; margin:0 auto 56px; text-align:center; }
    .section-head h2 {
        font-size:42px; line-height:1.1; font-weight:800; letter-spacing:-1px;
        margin:12px 0 16px;
    }
