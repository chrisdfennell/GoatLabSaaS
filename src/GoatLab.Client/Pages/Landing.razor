    // (chrisdfennell/GoatLabSaaS). Two products, two repos:
    //   - GoatLab     — self-hosted, run on your own hardware (Pi, NAS, VPS)
    //   - GoatLabSaaS — this hosted product (Stripe billing, multi-tenant)
    private const string RepoUrl = "https://github.com/chrisdfennell/GoatLab";

    private List<BillingService.PublicPlan>? _plans;

    protected override async Task OnInitializedAsync()
    {
        try { _plans = await BillingApi.GetPublicPlansAsync(); }
        catch { _plans = new(); /* if the API is unreachable, show empty */ }
    }

    // Middle plan in an odd-count list gets the "Most popular" badge.
    // For even counts, plan index floor(count/2)-1 is used — tweak if you want.
    private static bool IsFeaturedPlan(int index, int total)
        => total > 1 && index == total / 2;

    private static string CtaLabel(BillingService.PublicPlan plan)
    {
        if (plan.PriceMonthlyCents == 0) return "Start free";
        if (plan.TrialDays > 0) return $"Start {plan.TrialDays}-day trial";
        return $"Get {plan.Name}";
    }

    // "ShowRecords" → "Show records"
    private static string FeatureLabel(string feature)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < feature.Length; i++)
        {
            if (i > 0 && char.IsUpper(feature[i])) sb.Append(' ');
            sb.Append(i == 0 ? feature[i] : char.ToLower(feature[i]));
        }
        return sb.ToString();
    }

    private record Feature(string Title, string Body, string Icon, string Bg, string Fg);

    private readonly Feature[] _features = new[]
    {
