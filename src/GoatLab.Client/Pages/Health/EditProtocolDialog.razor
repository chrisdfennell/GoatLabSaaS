@inject ProtocolService ProtocolSvc
@inject HealthService HealthSvc
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="model.Name" Label="Name" Variant="Variant.Outlined" Required />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="string" @bind-Value="model.AppliesTo" Label="Applies to" Variant="Variant.Outlined" Clearable>
                    <MudSelectItem Value="@("Doe")">Doe</MudSelectItem>
                    <MudSelectItem Value="@("Buck")">Buck</MudSelectItem>
                    <MudSelectItem Value="@("Kid")">Kid</MudSelectItem>
                    <MudSelectItem Value="@("Adult")">Adult</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Doses (@model.Doses.Count)</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="AddDose">Add dose</MudButton>
                </div>
            </MudItem>

            @{ var doseList = model.Doses as List<ProtocolDose> ?? model.Doses.ToList(); }
            @for (int i = 0; i < doseList.Count; i++)
            {
                var idx = i;
                var dose = doseList[idx];
                <MudItem xs="12">
                    <MudPaper Outlined Class="pa-3" Style="border-left:3px solid #ad1457;">
                        <MudGrid>
                            <MudItem xs="12" sm="5">
                                <MudTextField @bind-Value="dose.Title" Label="Dose title" Variant="Variant.Outlined" Required />
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <MudNumericField T="int" @bind-Value="dose.DayOffset" Label="Day offset" Variant="Variant.Outlined"
                                                 HelperText="0 = on apply date" />
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <MudSelect T="MedicalRecordType" @bind-Value="dose.RecordType" Label="Type" Variant="Variant.Outlined">
                                    @foreach (var t in Enum.GetValues<MedicalRecordType>())
                                    {
                                        <MudSelectItem Value="@t">@t</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudSelect T="RecurrenceInterval" @bind-Value="dose.Recurrence" Label="Repeats" Variant="Variant.Outlined">
                                    @foreach (var r in Enum.GetValues<RecurrenceInterval>())
                                    {
                                        <MudSelectItem Value="@r">@r</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="dose.MedicationId" Label="Medication (optional)" Variant="Variant.Outlined" Clearable>
                                    @if (medications != null)
                                    {
                                        @foreach (var m in medications)
                                        {
                                            <MudSelectItem Value="@((int?)m.Id)">@m.Name</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="dose.Notes" Label="Notes" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" Class="d-flex justify-end">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => RemoveDose(idx))" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@(saving || string.IsNullOrWhiteSpace(model.Name))">
            @(saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public VaccinationProtocol? Existing { get; set; }

    private VaccinationProtocol model = new();
    private List<Medication>? medications;
    private bool saving;

    protected override async Task OnInitializedAsync()
    {
        medications = await HealthSvc.GetMedicationsAsync();
        if (Existing != null)
        {
            model = new VaccinationProtocol
            {
                Id = Existing.Id,
                Name = Existing.Name,
                Description = Existing.Description,
                AppliesTo = Existing.AppliesTo,
                IsBuiltIn = Existing.IsBuiltIn,
                Doses = Existing.Doses.Select(d => new ProtocolDose
                {
                    Id = d.Id,
                    Title = d.Title,
                    RecordType = d.RecordType,
                    MedicationId = d.MedicationId,
                    DayOffset = d.DayOffset,
                    Recurrence = d.Recurrence,
                    SortOrder = d.SortOrder,
                    Notes = d.Notes
                }).ToList()
            };
        }
    }

    private void AddDose() => model.Doses.Add(new ProtocolDose
    {
        Title = "New dose",
        DayOffset = model.Doses.Any() ? model.Doses.Max(d => d.DayOffset) + 30 : 0,
        Recurrence = RecurrenceInterval.None,
        RecordType = MedicalRecordType.Vaccination
    });

    private void RemoveDose(int idx)
    {
        var list = model.Doses.ToList();
        if (idx < 0 || idx >= list.Count) return;
        list.RemoveAt(idx);
        model.Doses = list;
    }

    private async Task Save()
    {
        saving = true;
        try
        {
            if (Existing == null)
                await ProtocolSvc.CreateAsync(model);
            else
                await ProtocolSvc.UpdateAsync(model);
            Snackbar.Add("Protocol saved", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
