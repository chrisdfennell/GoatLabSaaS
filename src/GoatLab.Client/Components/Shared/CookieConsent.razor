@inject IJSRuntime JS

@if (_visible)
{
    <div class="cookie-banner" role="dialog" aria-label="Cookie consent">
        <div class="cookie-text">
            <MudIcon Icon="@Icons.Material.Filled.Cookie" Size="Size.Small" Class="mr-2" />
            <span>
                We use a single session cookie to keep you signed in. No advertising or analytics
                cookies. See our <a href="/privacy">privacy policy</a> for details.
            </span>
        </div>
        <div class="cookie-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="AcceptAsync">
                Got it
            </MudButton>
        </div>
    </div>
}

<style>
    .cookie-banner {
        position: fixed;
        bottom: 16px;
        left: 16px;
        right: 16px;
        max-width: 720px;
        margin: 0 auto;
        background: #1a2421;
        color: #fff;
        padding: 12px 16px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 6px 24px rgba(0,0,0,0.25);
        z-index: 2000;
        font-size: 0.9rem;
    }
    .cookie-text { flex: 1; display: flex; align-items: center; }
    .cookie-banner a { color: #a5d6a7; text-decoration: underline; }
    @@media (max-width: 600px) {
        .cookie-banner { flex-direction: column; align-items: stretch; gap: 8px; }
    }
</style>

@code {
    private const string StorageKey = "goatlab.cookieConsent";
    private bool _visible;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var value = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
            if (string.IsNullOrEmpty(value))
            {
                _visible = true;
                StateHasChanged();
            }
        }
        catch { /* localStorage unavailable — fail silent */ }
    }

    private async Task AcceptAsync()
    {
        try { await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, "accepted"); }
        catch { /* ignore */ }
        _visible = false;
    }
}
