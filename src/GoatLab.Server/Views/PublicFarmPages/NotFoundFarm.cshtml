@model string
@{
    ViewData["Title"] = "Farm not found — GoatLab";
    ViewData["Description"] = "The farm you're looking for doesn't exist or hasn't enabled their public page.";
    Context.Response.StatusCode = 404;
}

<div class="empty-state" style="margin-top: 40px;">
    <div class="icon">🔍</div>
    <h1 style="margin: 8px 0;">Farm not found</h1>
    <p>
        The slug <code>@Model</code> doesn't match any farm with a public page enabled.
    </p>
    <p>
        <a class="cta-button" href="/breeds">Browse all breeders</a>
    </p>
</div>
