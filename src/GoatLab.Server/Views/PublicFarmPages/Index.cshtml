@using GoatLab.Shared.DTOs
@using GoatLab.Server.Controllers
@model List<PublicGoatListItemDto>
@{
    var slug = (string?)ViewData["FarmSlug"] ?? "";
    var name = (string?)ViewData["FarmName"] ?? slug;
    var location = (string?)ViewData["FarmLocation"];
    var contactEmail = (string?)ViewData["ContactEmail"];
    var listingCount = Model.Count;
}

<div class="breadcrumbs">
    <a href="/">GoatLab</a>
    <span class="sep">›</span>
    <a href="/breeds">Browse breeders</a>
    <span class="sep">›</span>
    <span>@name</span>
</div>

<div class="farm-header">
    <div>
        <span class="eyebrow">Public farm page</span>
        <h1>@name</h1>
        @if (!string.IsNullOrEmpty(location))
        {
            <p class="lede">📍 @location · @listingCount @(listingCount == 1 ? "goat" : "goats") for sale</p>
        }
        else
        {
            <p class="lede">@listingCount @(listingCount == 1 ? "goat" : "goats") for sale</p>
        }
    </div>
    @if (!string.IsNullOrEmpty(contactEmail))
    {
        <a class="cta-button" href="mailto:@contactEmail?subject=Inquiry%20from%20GoatLab%20listing">Contact seller</a>
    }
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="icon">🐐</div>
        <p>No goats currently listed for sale.</p>
        <p style="font-size:0.9rem;">Check back soon, or <a href="/breeds">browse other breeders</a>.</p>
    </div>
}
else
{
    <div class="goats-grid">
        @foreach (var g in Model)
        {
            <a class="goat-card" href="/pub/@slug/@g.Id">
                <div class="goat-card-photo @(string.IsNullOrEmpty(g.PrimaryPhotoUrl) ? "empty" : "")">
                    @if (!string.IsNullOrEmpty(g.PrimaryPhotoUrl))
                    {
                        <img src="@g.PrimaryPhotoUrl" alt="@g.Name" loading="lazy" />
                    }
                    else
                    {
                        <span>🐐</span>
                    }
                </div>
                <div class="goat-card-body">
                    <div class="goat-card-name">@g.Name</div>
                    <div class="goat-card-meta">
                        @(g.Breed ?? "Unknown breed") · @g.Gender
                        @if (g.DateOfBirth.HasValue)
                        {
                            <span> · @PublicFarmPagesController.AgeString(g.DateOfBirth.Value)</span>
                        }
                    </div>
                    @if (g.AskingPriceCents.HasValue)
                    {
                        <div class="goat-card-price">$@((g.AskingPriceCents.Value / 100m).ToString("N0"))</div>
                    }
                </div>
            </a>
        }
    </div>
}

<div class="farm-footer-cta">
    <p>
        Are you a breeder? <a href="/register">Start your own free GoatLab farm</a> and list your goats here.
    </p>
</div>

<style>
    .farm-header { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 28px; }
    .farm-header h1 { margin: 6px 0 6px 0; }
    .farm-header .lede { margin: 0; }

    .goats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }
    .goat-card {
        display: block;
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .goat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); text-decoration: none; }
    .goat-card-photo { aspect-ratio: 4 / 3; background: #f5f5f5; }
    .goat-card-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .goat-card-photo.empty { display: flex; align-items: center; justify-content: center; font-size: 3rem; color: #bbb; }
    .goat-card-body { padding: 12px 14px; }
    .goat-card-name { font-weight: 700; font-size: 1.1rem; }
    .goat-card-meta { font-size: 0.88rem; color: #6b7a70; margin-top: 2px; }
    .goat-card-price { color: #2e7d32; font-weight: 700; font-size: 1.05rem; margin-top: 6px; }

    .farm-footer-cta {
        margin-top: 40px;
        padding: 20px;
        background: #f1f8e9;
        border-radius: 10px;
        text-align: center;
        color: #1b5e20;
        font-size: 0.95rem;
    }
</style>
