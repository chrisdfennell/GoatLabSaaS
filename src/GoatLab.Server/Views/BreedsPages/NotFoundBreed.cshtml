@model string
@{
    ViewData["Title"] = "Breed not found — GoatLab";
    ViewData["Description"] = "No farms currently list this breed on GoatLab.";
}

<div class="empty-state">
    <div class="icon">🔍</div>
    <h1 style="margin: 8px 0;">Breed not found</h1>
    <p>No farms are currently listing <strong>@Model</strong> goats on GoatLab.</p>
    <p style="margin-top:16px;"><a class="cta-button" href="/breeds">Browse all breeds</a></p>
</div>
