{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/goatlab-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver,1433;Database=GoatLab;User Id=sa;Password=__SET_VIA_ENV__;TrustServerCertificate=True;Encrypt=True;"
  },
  "SuperAdmin": {
    "Emails": []
  },
  "GoogleMaps": {
    "ApiKey": ""
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "GoatLab",
    "UseSsl": true
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": "",
    "FarmPriceId": "",
    "DairyPriceId": "",
    "TrialDays": 14
  },
  "Sentry": {
    "Dsn": "",
    "TracesSampleRate": 0.0
  },
  "Backup": {
    "AppPath": null,
    "SqlServerPath": null,
    "Offsite": {
      "Enabled": false,
      "Endpoint": "",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "Bucket": "",
      "Prefix": "goatlab/db/",
      "RetentionDays": 30
    }
  }
}
