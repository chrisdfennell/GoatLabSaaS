# SQL Server sa password. Min 8 chars, must include upper, lower, digit, and symbol.
# Copy this file to .env and set a strong password before running `docker compose up`.
SA_PASSWORD=

# Host port the app binds to. QNAP Container Station already uses 8080,
# so the default is 8090. Pick any free port on your NAS.
APP_PORT=8090
# Host port for HTTPS. Browse to https://goatlab.local:${APP_HTTPS_PORT}
# after generating certs/app.pfx (see certs/README.md + tools/certs/gen-app-cert.sh).
APP_HTTPS_PORT=8443
# Password for certs/app.pfx. mkcert writes .pfx files with the default
# password "changeit" — keep this in sync or re-export the .pfx.
CERT_PASSWORD=changeit

# Google Maps JavaScript API key — served to the client for the farm map.
# Restrict the key to your domain(s) in the Google Cloud console; the browser
# sees it in the script URL either way, so it is not a secret but should be
# referrer-locked. Leave blank to disable the map.
GOOGLE_MAPS_API_KEY=

# Outbound SMTP for password reset + email confirmation emails.
# Leave SMTP_HOST blank to disable email (a no-op sender will log and drop).
# For local dev, point this at the Mailpit container (service "mailpit", port 1025).
# For production, use a real relay (SendGrid, SES, Postmark, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=GoatLab
# true = STARTTLS on 587 / SslOnConnect on 465. Set false only for a trusted internal relay.
SMTP_USE_SSL=true

# Identity: require users to click the confirmation link before they can log in.
# Leave false until SMTP is wired, otherwise new users are locked out.
IDENTITY_REQUIRE_CONFIRMED_EMAIL=false

# Stripe. Get keys from https://dashboard.stripe.com/apikeys (test mode first).
# Create two Products (Farm $19/mo, Dairy $49/mo) and paste their price IDs below.
# Webhook secret comes from dashboard.stripe.com/webhooks after adding an endpoint
# pointed at https://your-domain/api/billing/webhook. Leave blank to disable billing.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FARM_PRICE_ID=
STRIPE_DAIRY_PRICE_ID=
STRIPE_TRIAL_DAYS=14

# Sentry error monitoring. Create a project at https://sentry.io and paste the
# DSN here. Leave blank to disable (Sentry SDK becomes a no-op).
SENTRY_DSN=
# 0.0 = no performance tracing. Set to 0.1 or so if you want partial tracing.
SENTRY_TRACES_SAMPLE_RATE=0.0

# Offsite daily DB backup to S3-compatible storage (AWS S3, Backblaze B2,
# Wasabi, DigitalOcean Spaces, MinIO, etc). Leave Enabled=false to skip.
# For B2: set Endpoint=https://s3.us-west-001.backblazeb2.com (or your region).
BACKUP_OFFSITE_ENABLED=false
BACKUP_OFFSITE_ENDPOINT=
BACKUP_OFFSITE_REGION=us-east-1
BACKUP_OFFSITE_ACCESS_KEY=
BACKUP_OFFSITE_SECRET_KEY=
BACKUP_OFFSITE_BUCKET=
BACKUP_OFFSITE_PREFIX=goatlab/db/
BACKUP_OFFSITE_RETENTION_DAYS=30

# WebAuthn (passkeys). RpId = the registrable domain (the browser enforces
# this — must match the domain the user sees). Origin = the full URL the
# client loads from. For dev both default to localhost. For prod, set both to
# your real domain, e.g. WEBAUTHN_RP_ID=goatlab.example / WEBAUTHN_ORIGIN=https://goatlab.example
WEBAUTHN_RP_ID=goatlab.local
WEBAUTHN_ORIGIN=https://goatlab.local:8443

# Web Push (VAPID). Generate a fresh keypair with `npx web-push generate-vapid-keys`.
# PushService is a no-op when either key is blank, so leave them empty to disable
# push notifications entirely. Subject is a mailto: URI required by RFC 8292.
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_SUBJECT=mailto:admin@blah.local
