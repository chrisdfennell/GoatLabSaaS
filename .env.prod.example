# Production environment template — copy to .env on the VPS and fill in.
# DO NOT commit the real .env (it's gitignored).

# === Database ===
# Generate a strong random password — SQL Server requires upper, lower, digit, symbol, 8+ chars.
# Suggested: openssl rand -base64 32 | tr -d '/+=' | head -c 28 ; echo "!"
SA_PASSWORD=

# === Email (Brevo) ===
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@goatlab.app
SMTP_FROM_NAME=GoatLab
SMTP_USE_SSL=true

# Require email confirmation before signup completes. Safe to enable in prod
# once SMTP is verified.
IDENTITY_REQUIRE_CONFIRMED_EMAIL=true

# === Stripe (test mode is fine for soft-launch; switch to live keys for real customers) ===
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get the webhook secret from a NEW endpoint registered at
# dashboard.stripe.com/webhooks pointing to https://goatlab.app/api/billing/webhook
STRIPE_WEBHOOK_SECRET=

# === WebAuthn (passkeys) ===
WEBAUTHN_RP_ID=goatlab.app
WEBAUTHN_ORIGIN=https://goatlab.app

# === Web Push (VAPID) ===
# Generate a fresh keypair: npx web-push generate-vapid-keys
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_SUBJECT=mailto:noreply@goatlab.app

# === Google Maps (optional) ===
GOOGLE_MAPS_API_KEY=

# === Sentry (optional) ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# === Offsite DB backups (optional — leave Enabled=false to skip) ===
BACKUP_OFFSITE_ENABLED=false
BACKUP_OFFSITE_ENDPOINT=
BACKUP_OFFSITE_REGION=us-east-1
BACKUP_OFFSITE_ACCESS_KEY=
BACKUP_OFFSITE_SECRET_KEY=
BACKUP_OFFSITE_BUCKET=
BACKUP_OFFSITE_PREFIX=goatlab/db/
BACKUP_OFFSITE_RETENTION_DAYS=30
